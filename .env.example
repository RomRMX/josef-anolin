# Copy this file to `.env` for local dev, and set the same keys in Vercel for
# production. Never commit a real `.env`. In dev, everything below is optional —
# the admin falls back to a local-file store and the password "admin".

# ---- Admin login: Google sign-in (recommended) ----
# Create an OAuth 2.0 "Web application" client at
# https://console.cloud.google.com/apis/credentials and add these redirect URIs:
#   http://localhost:4321/api/admin/auth/callback         (local dev)
#   https://www.josefanolin.com/api/admin/auth/callback   (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The ONLY Google accounts allowed into the admin (comma-separated).
# Intentionally just two people: the domain owner and the developer.
ADMIN_ALLOWED_EMAILS=josefanolin@gmail.com, rpragasa@gmail.com

# ---- Admin login: password (optional fallback) ----
# Leave blank in production to make the admin Google-only.
# (Defaults to "admin" in local dev if unset.)
ADMIN_PASSWORD=
# Long random string used to sign the session cookie.
ADMIN_SECRET=

# ---- Content store (required in production to SAVE edits) ----
# Create a KV / Upstash Redis store in Vercel and connect it; these get injected.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Photo uploads (optional) ----
# Create a Vercel Blob store; this gets injected. Without it, photos can still
# be added by URL.
BLOB_READ_WRITE_TOKEN=

# ---- Shop ----
# Stripe server-side secret for the /api/checkout endpoint.
# Test key starts with "sk_test_", live key with "sk_live_".
STRIPE_SECRET_KEY=
