---
// TODO: replace `#` with the real merch URL when it's live.
const SHOP_URL = "#";
---

<section class="relative h-full overflow-hidden bg-[color:var(--color-accent-2)]">
  <div class="relative h-full flex flex-col">
    {/* Visual area — title+button left, merch placeholder right. */}
    <div class="flex-1 min-h-0">
      <div
        class="relative h-full max-w-7xl mx-auto px-6 md:px-10 grid grid-cols-1 md:grid-cols-[1fr_1fr] items-end md:items-center gap-4 md:gap-8 pt-20 md:pt-24"
      >
        <div class="flex flex-col items-start gap-5 z-10 self-center">
          <h2
            class="font-[family-name:var(--font-display)] text-7xl md:text-8xl lg:text-9xl tracking-wide text-black leading-[0.85]"
          >
            SHOP
          </h2>
          <p class="text-black/85 text-base md:text-lg max-w-xs font-medium">
            Tees, hats, stickers — official Josef Anolin merch.
          </p>
          <a
            href={SHOP_URL}
            class="inline-block px-10 py-3.5 bg-black text-[color:var(--color-accent-2)] font-extrabold tracking-widest text-base rounded-full hover:bg-neutral-900 hover:shadow-[0_12px_32px_rgba(0,0,0,0.35)] active:bg-black transition"
          >
            SHOP NOW
          </a>
        </div>
        <div class="hidden md:flex justify-end items-end h-full pb-6">
          {/* Merch image placeholder. Drop a product image at /public/shop-image.png
              and swap this <div> for an <img>. */}
          <div
            class="w-full max-w-md aspect-square border-2 border-dashed border-black/30 rounded-lg flex items-center justify-center text-black/40 text-xs tracking-[0.3em] font-bold"
          >
            MERCH IMAGE
          </div>
        </div>
      </div>
    </div>

    {/* Tagline band — solid black to mirror the hero's bio band. */}
    <div class="relative z-10 px-6 pb-8 pt-5 md:pb-12 md:pt-6 text-center bg-[color:var(--color-bg)]">
      <p class="text-neutral-300 tracking-[0.25em] text-xs md:text-sm font-bold">
        REP THE BRAND. WEAR THE BIT.
      </p>
    </div>
  </div>
</section>
