---
// TODO: replace `#` with the real merch URL when it's live.
const SHOP_URL = "#";

// Tee cluster — each shirt links to its product page. Null for now.
// Slight horizontal nudges keep the scattered look as the column scrolls.
const tees = [
  { src: "/t1.png", href: "#", offset: "ml-[6%]"   },
  { src: "/t2.png", href: "#", offset: "ml-[22%]"  },
  { src: "/t2.png", href: "#", offset: "ml-[2%]"   },
  { src: "/t1.png", href: "#", offset: "ml-[24%]"  },
  { src: "/t1.png", href: "#", offset: "ml-[12%]"  },
];
---

<section class="relative h-full overflow-hidden bg-[color:var(--color-accent-2)]">
  <div
    class="relative h-full max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-[minmax(280px,1fr)_3fr] items-start gap-4 md:gap-12 pt-[250px]"
  >
    <div class="flex flex-col md:items-end items-start gap-5 z-10 md:text-right">
      <h2
        class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide text-black"
      >
        SHOP
      </h2>
      <p class="text-black/85 text-base md:text-lg max-w-xs font-medium">
        Tees. hats, stickers<br />Official Merch right here
      </p>
      <a
        href={SHOP_URL}
        class="inline-block px-10 py-3.5 bg-black text-[color:var(--color-accent-2)] font-extrabold tracking-widest text-base rounded-full hover:bg-neutral-900 hover:shadow-[0_12px_32px_rgba(0,0,0,0.35)] active:bg-black transition"
      >
        SHOP NOW
      </a>
    </div>

    {/* Tees: vertical stack with its own scroll once the shop card is fully in view.
        The card itself is sticky inside .stack — once it's covered the viewport,
        further wheel/touch input is captured here and scrolls the column instead
        of advancing the deck, until the user reaches the bottom of the column. */}
    <div
      class="hidden md:block self-stretch h-[calc(100dvh-250px)] overflow-y-auto overscroll-contain pr-1 shop-tees"
    >
      <div class="flex flex-col gap-16 pb-16">
        {tees.map((t) => (
          <a
            href={t.href}
            aria-label="Shop this tee"
            class={`block w-[60%] ${t.offset} transition-transform duration-200 hover:scale-105 hover:-rotate-2 focus-visible:scale-105`}
          >
            <img src={t.src} alt="" class="w-full h-auto select-none" draggable="false" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Subtle scrollbar inside the tee column so it's discoverable but not loud. */
  .shop-tees {
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.35) transparent;
  }
  .shop-tees::-webkit-scrollbar { width: 6px; }
  .shop-tees::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.35);
    border-radius: 3px;
  }
</style>
