---
const tees = [
  {
    id: "joe-tee-classic",
    src: "/shop/tee-black-front.png",
    name: "Joe Dobo Classic Tee",
    description:
      "Soft cotton, blast yellow logo on jet black. Roomy fit so your beer doesn't have to compete for space.",
    price: 3000,
  },
  {
    id: "joe-tee-tour",
    src: "/shop/items/blanktees_navy-a.png",
    name: "Tour Tee — Bay Area",
    description:
      "Limited print celebrating Oakland to LA and back. Worn by every comic too cheap to buy two.",
    price: 3500,
  },
  {
    id: "joe-tee-stand-up",
    src: "/shop/tee-black-front-2.png",
    name: "Stand Up Comedian Tee",
    description:
      "Anton block letters across the chest. The shirt that says you're funnier than the venue paid for.",
    price: 3000,
  },
  {
    id: "joe-hoodie",
    src: "/shop/hoodie-black.png",
    name: "Joe Dobo Hoodie",
    description:
      "Heavyweight fleece, oversized fit. The unofficial uniform of every greenroom from Oakland to LA.",
    price: 6500,
  },
  {
    id: "joe-tote",
    src: "/shop/items/tote_black.png",
    name: "Joe Dobo Tote",
    description:
      "Carry your snacks, your set list, your delusions. Roomy enough for all three.",
    price: 2200,
  },
  {
    id: "joe-trucker",
    src: "/shop/items/hat_trucker_camo.png",
    name: "Trucker Hat",
    description:
      "Camo crown, mesh back, snapback close. Goes with everything in your closet that's also black.",
    price: 2800,
  },
];

const fmt = (cents: number) =>
  (cents / 100).toLocaleString("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });
---

<div id="shop-inner">
  <h2 class="section-h2 section-h2--lead">SHOP</h2>
  <ul class="tee-list">
    {tees.map((t) => (
      <li class="tee-row">
        <button
          type="button"
          class="tee-row__media"
          data-zoom-src={t.src}
          data-zoom-name={t.name}
          aria-label={`Zoom ${t.name}`}
        >
          <img src={t.src} alt={t.name} draggable="false" />
        </button>
        <div class="tee-row__body">
          <h3 class="tee-row__name">{t.name}</h3>
          <p class="tee-row__desc">{t.description}</p>
          <div class="tee-row__buy">
            <span class="tee-row__price">{fmt(t.price)}</span>
            <button
              type="button"
              class="add-to-cart-btn"
              data-product-id={t.id}
              data-product-name={t.name}
              data-product-price={t.price}
              data-product-src={t.src}
              aria-label={`Add ${t.name} to cart`}
            >
              ADD TO CART
            </button>
          </div>
        </div>
      </li>
    ))}
  </ul>
</div>

<div
  class="product-zoom"
  data-product-zoom
  role="dialog"
  aria-modal="true"
  aria-label="Product image"
  hidden
>
  <button
    type="button"
    class="product-zoom__backdrop"
    data-zoom-close
    aria-label="Close zoom"
  ></button>
  <div class="product-zoom__panel">
    <img class="product-zoom__img" alt="" />
    <p class="product-zoom__caption" data-zoom-caption></p>
    <button
      type="button"
      class="product-zoom__close"
      data-zoom-close
      aria-label="Close zoom"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>
  </div>
</div>

<style>
  .tee-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }
  .tee-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  .tee-row__media {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    background: #3481FF;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 0.75rem;
    cursor: zoom-in;
    overflow: hidden;
    transition: transform 160ms var(--ease-out-strong),
                box-shadow 160ms var(--ease-out-strong);
  }
  .tee-row__media:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(52, 129, 255, 0.35);
  }
  .tee-row__media:active { transform: translateY(-1px) scale(0.98); }
  .tee-row__media:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }
  .tee-row__media img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
    transition: transform 280ms var(--ease-out-strong);
  }
  .tee-row__media:hover img { transform: scale(1.05); }

  .product-zoom[hidden] { display: none; }
  .product-zoom {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    padding: 4vmin;
    animation: product-zoom-in 180ms var(--ease-out-strong);
  }
  .product-zoom__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.86);
    backdrop-filter: blur(6px);
    border: 0;
    padding: 0;
    cursor: zoom-out;
  }
  .product-zoom__panel {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 900px);
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .product-zoom__img {
    max-width: 100%;
    max-height: 78vh;
    object-fit: contain;
    background: #3481FF;
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    user-select: none;
  }
  .product-zoom__caption {
    margin: 0;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 1rem;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.92);
    text-align: center;
  }
  .product-zoom__close {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    cursor: pointer;
    transition: background-color 140ms var(--ease-out-strong),
                color 140ms var(--ease-out-strong);
  }
  .product-zoom__close:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  @keyframes product-zoom-in {
    from { opacity: 0; transform: scale(0.98); }
    to   { opacity: 1; transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .product-zoom,
    .tee-row__media,
    .tee-row__media img { animation: none; transition: none; }
  }
  .tee-row__name {
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    margin: 0 0 0.4rem;
  }
  .tee-row__desc {
    margin: 0 0 0.85rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.72);
    max-width: 36ch;
  }
  .tee-row__buy {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .tee-row__price {
    font-weight: 700;
    color: var(--color-accent-2);
    font-size: 1rem;
  }
  .add-to-cart-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: var(--color-ink);
    border: 1px solid rgba(255, 255, 255, 0.18);
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    padding: 0.55rem 0.95rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 160ms var(--ease-out-strong),
                color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .add-to-cart-btn:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  .add-to-cart-btn:active { transform: scale(0.97); }
  .add-to-cart-btn.is-added {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }

  @media (max-width: 899px) {
    .tee-row {
      grid-template-columns: 110px 1fr;
      gap: 1rem;
    }
    .tee-row__name { font-size: 1.2rem; }
    .tee-row__desc { font-size: 0.85rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".add-to-cart-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const detail = {
        id: btn.dataset.productId!,
        name: btn.dataset.productName!,
        price: Number(btn.dataset.productPrice),
        src: btn.dataset.productSrc!,
      };
      window.dispatchEvent(new CustomEvent("cart:add", { detail }));
      btn.classList.add("is-added");
      setTimeout(() => btn.classList.remove("is-added"), 600);
    });
  });

  const zoom = document.querySelector<HTMLDivElement>("[data-product-zoom]");
  if (zoom) {
    const zoomImg = zoom.querySelector<HTMLImageElement>(".product-zoom__img")!;
    const zoomCap = zoom.querySelector<HTMLElement>("[data-zoom-caption]")!;
    let lastTrigger: HTMLElement | null = null;

    const open = (src: string, name: string, trigger: HTMLElement) => {
      lastTrigger = trigger;
      zoomImg.src = src;
      zoomImg.alt = name;
      zoomCap.textContent = name;
      zoom.hidden = false;
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      zoom.hidden = true;
      zoomImg.removeAttribute("src");
      document.body.style.overflow = "";
      lastTrigger?.focus();
    };

    document
      .querySelectorAll<HTMLButtonElement>(".tee-row__media[data-zoom-src]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          open(btn.dataset.zoomSrc!, btn.dataset.zoomName || "", btn);
        });
      });

    zoom
      .querySelectorAll<HTMLElement>("[data-zoom-close]")
      .forEach((el) => el.addEventListener("click", close));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !zoom.hidden) close();
    });
  }
</script>
