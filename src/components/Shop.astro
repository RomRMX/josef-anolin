---
// Each tee is a full product. id is used by the cart store; price in cents.
const tees = [
  {
    id: "joe-tee-classic",
    src: "/t1.png",
    name: "Joe Dobo Classic Tee",
    description:
      "Soft cotton, blast yellow logo on jet black. Roomy fit so your beer doesn't have to compete for space.",
    price: 3000,
  },
  {
    id: "joe-tee-tour",
    src: "/t2.png",
    name: "Tour Tee — Bay Area",
    description:
      "Limited print celebrating Oakland to LA and back. Worn by every comic too cheap to buy two.",
    price: 3500,
  },
  {
    id: "joe-tee-stand-up",
    src: "/t2.png",
    name: "Stand Up Comedian Tee",
    description:
      "Anton block letters across the chest. The shirt that says you're funnier than the venue paid for.",
    price: 3000,
  },
  {
    id: "joe-tee-android",
    src: "/t1.png",
    name: "Green Bubble Tee",
    description:
      "For everyone whose iMessage threads are a constant disappointment. Charcoal heather, accent green print.",
    price: 3200,
  },
  {
    id: "joe-tee-headliner",
    src: "/t1.png",
    name: "Headliner Tee",
    description:
      "Heavyweight cotton, gold foil logo. Wear it once, get asked to open at every open mic in three counties.",
    price: 4000,
  },
];

const fmt = (cents: number) =>
  (cents / 100).toLocaleString("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });
---

<section class="relative h-full overflow-hidden bg-[color:var(--color-accent-2)]">
  <div
    class="relative h-full max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-[minmax(280px,1fr)_3fr] items-start gap-4 md:gap-12 pt-16 md:pt-[180px]"
  >
    <div class="flex flex-col md:items-end items-start gap-5 z-10 md:text-right">
      <h2
        class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide text-black"
      >
        SHOP
      </h2>
      <p class="text-black/85 text-base md:text-lg max-w-xs font-medium">
        Tees, hats, stickers<br />Official Merch right here
      </p>
    </div>

    {/* MOBILE: horizontal marquee of tee+info cards. */}
    <div class="md:hidden -mx-6 mt-[-100px] overflow-hidden shop-tees-marquee">
      <div class="shop-tees-marquee-track flex gap-4 w-max">
        {[...tees, ...tees].map((t, i) => (
          <article class="shrink-0 w-[80vw] max-w-[360px] flex flex-col items-stretch gap-3 px-3">
            <img src={t.src} alt={t.name} class="w-full h-auto select-none" draggable="false" />
            <div class="flex flex-col gap-2 px-1">
              <h3 class="font-[family-name:var(--font-display)] text-2xl tracking-wide text-black leading-none">
                {t.name}
              </h3>
              <p class="text-sm text-black/75 leading-snug">{t.description}</p>
              <div class="flex items-center justify-between mt-1">
                <span class="font-bold text-base text-black">{fmt(t.price)}</span>
                <button
                  type="button"
                  class="add-to-cart-btn inline-flex items-center justify-center min-h-9 px-3 text-xs font-bold tracking-widest bg-black text-[color:var(--color-accent)] rounded-sm"
                  data-product-id={t.id}
                  data-product-name={t.name}
                  data-product-price={t.price}
                  data-product-src={t.src}
                  aria-label={`Add ${t.name} to cart`}
                >
                  ADD TO CART
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  {/* DESKTOP: two-up parallax column — tee image on left, info on right. */}
  <div class="hidden md:block absolute top-[180px] left-1/2 w-full max-w-6xl -translate-x-1/2 px-6 pointer-events-none h-[calc(100dvh-180px)]">
    <div class="ml-auto w-[800px] h-full shop-tees-window pointer-events-auto">
      <div class="shop-tees-track relative will-change-transform">
        <div class="flex flex-col gap-12 pb-12">
          {tees.map((t) => (
            <article class="grid grid-cols-[260px_1fr] items-center gap-6">
              <button
                type="button"
                aria-label={`${t.name} image`}
                class="block w-full bg-transparent border-0 p-0 cursor-default transition-transform duration-200 hover:scale-105 hover:-rotate-2"
              >
                <img src={t.src} alt={t.name} class="w-full h-auto select-none" draggable="false" />
              </button>
              <div class="flex flex-col gap-3">
                <h3 class="font-[family-name:var(--font-display)] text-3xl xl:text-4xl tracking-wide text-black leading-none">
                  {t.name}
                </h3>
                <p class="text-sm xl:text-base text-black/75 leading-snug max-w-[360px]">
                  {t.description}
                </p>
                <div class="flex items-center gap-4 mt-1">
                  <span class="font-bold text-lg text-black">{fmt(t.price)}</span>
                  <button
                    type="button"
                    class="add-to-cart-btn inline-flex items-center justify-center min-h-10 px-4 text-xs font-bold tracking-widest bg-black text-[color:var(--color-accent)] rounded-sm"
                    data-product-id={t.id}
                    data-product-name={t.name}
                    data-product-price={t.price}
                    data-product-src={t.src}
                    aria-label={`Add ${t.name} to cart`}
                  >
                    ADD TO CART
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Translate the tee track upward as the user scrolls through the shop card's
  // sticky range. Identical math to the prior version.
  const shop = document.getElementById("shop");
  const teeTrack = document.querySelector<HTMLElement>(".shop-tees-track");
  const teeWindow = document.querySelector<HTMLElement>(".shop-tees-window");
  const mobileTrack = document.querySelector<HTMLElement>(".shop-tees-marquee-track");
  const mobileWindow = document.querySelector<HTMLElement>(".shop-tees-marquee");

  if (shop) {
    let start = 0;
    const measure = () => {
      let el: HTMLElement | null = shop;
      let y = 0;
      while (el) {
        y += el.offsetTop;
        el = el.offsetParent as HTMLElement | null;
      }
      start = y;
    };
    measure();

    let raf = 0;
    const update = () => {
      raf = 0;
      const range = Math.max(1, shop.offsetHeight - window.innerHeight);
      const p = Math.min(1, Math.max(0, (window.scrollY - start) / range));

      if (teeTrack && teeWindow) {
        const travel = teeTrack.scrollHeight + teeWindow.clientHeight;
        teeTrack.style.transform = `translate3d(0, ${-p * travel}px, 0)`;
      }

      if (mobileTrack && mobileWindow) {
        const travel = Math.max(0, mobileTrack.scrollWidth - mobileWindow.clientWidth);
        mobileTrack.style.transform = `translate3d(${-p * travel}px, 0, 0)`;
      }
    };
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      measure();
      update();
    });
    update();
  }

  // Add-to-cart wiring — defers to the global cart store mounted in Base.astro.
  document.querySelectorAll<HTMLButtonElement>(".add-to-cart-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const detail = {
        id: btn.dataset.productId!,
        name: btn.dataset.productName!,
        price: Number(btn.dataset.productPrice),
        src: btn.dataset.productSrc!,
      };
      window.dispatchEvent(new CustomEvent("cart:add", { detail }));
    });
  });
</script>

<style>
  .shop-tees-strip { scrollbar-width: none; }
  .shop-tees-strip::-webkit-scrollbar { display: none; }

  .add-to-cart-btn {
    transition: background-color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .add-to-cart-btn:active { transform: scale(0.97); }
  @media (hover: hover) and (pointer: fine) {
    .add-to-cart-btn:hover { background-color: rgb(38 38 38); }
  }
  /* "Added" pulse — applied for ~600ms after a successful add. */
  .add-to-cart-btn.is-added {
    background-color: var(--color-accent);
    color: black;
  }
</style>
