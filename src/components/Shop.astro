---
const tees = [
  {
    id: "joe-tee-classic",
    src: "/t1.png",
    name: "Joe Dobo Classic Tee",
    description:
      "Soft cotton, blast yellow logo on jet black. Roomy fit so your beer doesn't have to compete for space.",
    price: 3000,
  },
  {
    id: "joe-tee-tour",
    src: "/t2.png",
    name: "Tour Tee — Bay Area",
    description:
      "Limited print celebrating Oakland to LA and back. Worn by every comic too cheap to buy two.",
    price: 3500,
  },
  {
    id: "joe-tee-stand-up",
    src: "/t2.png",
    name: "Stand Up Comedian Tee",
    description:
      "Anton block letters across the chest. The shirt that says you're funnier than the venue paid for.",
    price: 3000,
  },
];

const fmt = (cents: number) =>
  (cents / 100).toLocaleString("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });
---

<div id="shop-inner">
  <h2 class="section-h2 section-h2--lead">SHOP</h2>
  <ul class="tee-list">
    {tees.map((t) => (
      <li class="tee-row">
        <div class="tee-row__media">
          <img src={t.src} alt={t.name} draggable="false" />
        </div>
        <div class="tee-row__body">
          <h3 class="tee-row__name">{t.name}</h3>
          <p class="tee-row__desc">{t.description}</p>
          <div class="tee-row__buy">
            <span class="tee-row__price">{fmt(t.price)}</span>
            <button
              type="button"
              class="add-to-cart-btn"
              data-product-id={t.id}
              data-product-name={t.name}
              data-product-price={t.price}
              data-product-src={t.src}
              aria-label={`Add ${t.name} to cart`}
            >
              ADD TO CART
            </button>
          </div>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .tee-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }
  .tee-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  .tee-row__media {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 0.75rem;
  }
  .tee-row__media img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
  }
  .tee-row__name {
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    margin: 0 0 0.4rem;
  }
  .tee-row__desc {
    margin: 0 0 0.85rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.72);
    max-width: 36ch;
  }
  .tee-row__buy {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .tee-row__price {
    font-weight: 700;
    color: var(--color-accent-2);
    font-size: 1rem;
  }
  .add-to-cart-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: var(--color-ink);
    border: 1px solid rgba(255, 255, 255, 0.18);
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    padding: 0.55rem 0.95rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 160ms var(--ease-out-strong),
                color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .add-to-cart-btn:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  .add-to-cart-btn:active { transform: scale(0.97); }
  .add-to-cart-btn.is-added {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }

  @media (max-width: 767px) {
    .tee-row {
      grid-template-columns: 110px 1fr;
      gap: 1rem;
    }
    .tee-row__name { font-size: 1.2rem; }
    .tee-row__desc { font-size: 0.85rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".add-to-cart-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const detail = {
        id: btn.dataset.productId!,
        name: btn.dataset.productName!,
        price: Number(btn.dataset.productPrice),
        src: btn.dataset.productSrc!,
      };
      window.dispatchEvent(new CustomEvent("cart:add", { detail }));
      btn.classList.add("is-added");
      setTimeout(() => btn.classList.remove("is-added"), 600);
    });
  });
</script>
