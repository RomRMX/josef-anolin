---
const socials = [
  { label: "Email", href: "mailto:bookings@josefanolin.com" },
  { label: "Instagram", href: "https://www.instagram.com/comedianjoe510/" },
  { label: "TikTok", href: "https://www.tiktok.com/@comedianjoe510" },
  { label: "YouTube", href: "https://www.youtube.com/@comedianjoe510" },
  { label: "Facebook", href: "https://www.facebook.com/JosefAnolinComedian" },
  { label: "Threads", href: "https://www.threads.com/@comedianjoe510" },
];
---

<section class="max-w-6xl mx-auto px-6 py-6 grid grid-cols-1 md:grid-cols-[minmax(180px,1fr)_3fr] gap-4 md:gap-12 items-start">
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide">
    HIT ME!
  </h2>
  <ul class="flex flex-wrap gap-2">
    {
      socials.map((s) => (
        <li>
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="inline-block px-4 py-1.5 border border-[color:var(--color-panel)] rounded-full text-sm tracking-wider hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] transition-colors"
          >
            {s.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>
<hr class="rule" />
