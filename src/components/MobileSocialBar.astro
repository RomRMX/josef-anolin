---
const socials = [
  { label: "Email", short: "@", href: "mailto:bookings@josefanolin.com" },
  { label: "Instagram", short: "IG", href: "https://www.instagram.com/comedianjoe510/" },
  { label: "TikTok", short: "TT", href: "https://www.tiktok.com/@comedianjoe510" },
  { label: "YouTube", short: "YT", href: "https://www.youtube.com/@comedianjoe510" },
  { label: "Facebook", short: "FB", href: "https://www.facebook.com/JosefAnolinComedian" },
  { label: "Threads", short: "TH", href: "https://www.threads.com/@comedianjoe510" },
];
---

{/* Mobile-only social bar pinned to viewport bottom. One row, 6 chips. */}
<nav
  class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-black border-t border-white/10"
  aria-label="Social links"
>
  <ul class="flex items-stretch justify-around px-2 py-2">
    {
      socials.map((s) => (
        <li class="flex-1">
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            aria-label={s.label}
            class="flex items-center justify-center min-h-9 mx-0.5 rounded-md bg-[color:var(--color-accent)] text-[11px] font-bold tracking-wider text-black hover:brightness-110 active:brightness-110 transition-[filter]"
          >
            {s.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
