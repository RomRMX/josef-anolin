---
const socials = [
  { label: "YouTube", href: "https://www.youtube.com/@comedianjoe510", icon: "/socials/social__0000_Layer-8.png" },
  { label: "Instagram", href: "https://www.instagram.com/comedianjoe510/", icon: "/socials/social__0003_Layer-5.png" },
  { label: "TikTok", href: "https://www.tiktok.com/@comedianjoe510?is_from_webapp=1&sender_device=pc", icon: "/socials/social__0002_Layer-6.png" },
  { label: "Facebook", href: "https://www.facebook.com/JosefAnolinComedian", icon: "/socials/social__0004_Layer-4.png" },
  { label: "Threads", href: "https://www.threads.com/@comedianjoe510", icon: "/socials/social__0001_Layer-7.png" },
  { label: "Email", href: "mailto:josefanolin@gmail.com", icon: "/socials/social__0005_Layer-3.png" },
];
---

{/* Mobile-only social bar pinned to viewport bottom. PNG glyph icons on the
    dark bar — matches the desktop header style. */}
<nav
  class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-[#0a0a0a] border-t border-white/10"
  aria-label="Social links"
>
  <ul class="flex items-center justify-center gap-7 px-4 py-2.5">
    {
      socials.map((s) => (
        <li>
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            aria-label={s.label}
            title={s.label}
            class="mobile-social-icon inline-flex items-center justify-center w-8 h-8 rounded-sm"
          >
            <img
              src={s.icon}
              alt=""
              class="w-6 h-6 select-none pointer-events-none"
            />
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .mobile-social-icon {
    transition: background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .mobile-social-icon:active {
    transform: scale(0.92);
    background-color: rgba(255, 255, 255, 0.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-social-icon { transition: background-color 160ms ease; }
    .mobile-social-icon:active { transform: none; }
  }
</style>
