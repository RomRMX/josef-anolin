---
import SocialIcon from "./SocialIcon.astro";

const socials = [
  { label: "YouTube",   href: "https://www.youtube.com/@comedianjoe510",                                  icon: "youtube"   as const },
  { label: "Instagram", href: "https://www.instagram.com/comedianjoe510/",                                icon: "instagram" as const },
  { label: "TikTok",    href: "https://www.tiktok.com/@comedianjoe510?is_from_webapp=1&sender_device=pc", icon: "tiktok"    as const },
  { label: "Facebook",  href: "https://www.facebook.com/JosefAnolinComedian",                             icon: "facebook"  as const },
  { label: "Threads",   href: "https://www.threads.com/@comedianjoe510",                                  icon: "threads"   as const },
  { label: "Email",     href: "mailto:josefanolin@gmail.com",                                             icon: "email"     as const },
];
---

{/* Mobile-only social bar pinned to viewport bottom. PNG glyph icons on the
    dark bar — matches the desktop header style. */}
<nav
  class="min-[900px]:hidden fixed bottom-0 left-0 right-0 z-50 bg-[#0a0a0a] border-t border-white/10"
  aria-label="Social links"
>
  {/* 6 × 44px chips + 5 × 24px gap + 32px padding = 416px on 1st-gen iPhone SE
      (320px) — gap auto-tightens via justify-between fallback at narrow widths. */}
  <ul class="flex items-center justify-around px-3 py-3">
    {
      socials.map((s) => (
        <li>
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            aria-label={s.label}
            title={s.label}
            class="mobile-social-icon inline-flex items-center justify-center w-11 h-11 rounded-sm text-[color:var(--socials-color)]"
          >
            <SocialIcon name={s.icon} class="w-8 h-8" />
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .mobile-social-icon {
    transition: background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .mobile-social-icon:active {
    transform: scale(0.92);
    background-color: rgba(255, 255, 255, 0.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-social-icon { transition: background-color 160ms ease; }
    .mobile-social-icon:active { transform: none; }
  }
</style>
