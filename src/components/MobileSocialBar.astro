---
const socials = [
  { label: "YouTube", icon: "youtube", href: "https://www.youtube.com/@comedianjoe510" },
  { label: "Instagram", icon: "instagram", href: "https://www.instagram.com/comedianjoe510/" },
  { label: "TikTok", icon: "tiktok", href: "https://www.tiktok.com/@comedianjoe510?is_from_webapp=1&sender_device=pc" },
  { label: "Facebook", icon: "facebook", href: "https://www.facebook.com/JosefAnolinComedian" },
  { label: "Threads", icon: "threads", href: "https://www.threads.com/@comedianjoe510" },
  { label: "Email", icon: "email", href: "mailto:josefanolin@gmail.com" },
];
---

{/* Mobile-only social bar pinned to viewport bottom. Icon chips, single row. */}
<nav
  class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-[#0a0a0a] border-t border-white/10"
  aria-label="Social links"
>
  <ul class="flex items-stretch justify-between px-3 py-1.5 gap-2">
    {
      socials.map((s) => (
        <li class="flex-1">
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            aria-label={s.label}
            title={s.label}
            class="mobile-social-icon flex items-center justify-center min-h-[26px] rounded-md bg-[color:var(--color-accent)] text-black hover:brightness-110 py-0.5"
          >
            {s.icon === "email" && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m22 7-10 6L2 7" />
              </svg>
            )}
            {s.icon === "instagram" && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="16" height="16" rx="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            )}
            {s.icon === "tiktok" && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.86a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.29z" />
              </svg>
            )}
            {s.icon === "youtube" && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z" />
              </svg>
            )}
            {s.icon === "facebook" && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z" />
              </svg>
            )}
            {s.icon === "threads" && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12.18 24h-.01c-3.71-.03-6.57-1.25-8.5-3.65C1.95 18.22 1.06 15.31 1 12.01v-.02c.06-3.3.95-6.21 2.67-8.34C5.6 1.25 8.46.03 12.17 0h.01c2.85.02 5.21.74 7.04 2.16 1.71 1.34 2.92 3.25 3.59 5.69l-2.05.6c-1.13-4.09-3.92-6.18-8.6-6.21-3.09.03-5.43 1.01-6.96 2.92C3.69 6.91 2.96 9.27 2.91 12c.05 2.74.78 5.1 2.18 6.85 1.53 1.91 3.86 2.89 6.95 2.92 2.78-.02 4.62-.66 6.15-2.13 1.74-1.68 1.71-3.74 1.16-4.99-.32-.74-.91-1.36-1.71-1.83-.2 1.43-.65 2.59-1.34 3.45-.92 1.16-2.23 1.79-3.89 1.87-1.27.06-2.49-.24-3.43-.85-1.13-.74-1.79-1.86-1.85-3.18-.06-1.27.43-2.43 1.39-3.27.92-.81 2.21-1.28 3.74-1.36 1.13-.06 2.18.05 3.18.31-.13-.81-.4-1.45-.81-1.91-.55-.62-1.41-.94-2.55-.95h-.04c-.91 0-2.16.25-2.95 1.43L8.71 7.13c1.06-1.6 2.79-2.48 5.07-2.48h.05c3.81.02 6.07 2.36 6.3 6.45.13.05.27.11.4.17 1.84.86 3.18 2.17 3.89 3.78 1 2.25 1.09 5.91-1.91 8.78-2.29 2.2-5.07 3.18-8.32 3.21z" />
              </svg>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .mobile-social-icon {
    transition: filter 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .mobile-social-icon:active { transform: scale(0.92); }
  @media (prefers-reduced-motion: reduce) {
    .mobile-social-icon { transition: filter 160ms ease; }
    .mobile-social-icon:active { transform: none; }
  }
</style>
