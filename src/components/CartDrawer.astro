---
// Cart + checkout + success flow. Static-site safe — payment is dummy.
// State lives in localStorage; events are window-level for loose coupling.
---

<div class="cart-overlay" data-state="closed" aria-hidden="true">
  <button
    type="button"
    class="cart-backdrop"
    aria-label="Close cart"
    tabindex="-1"
  ></button>

  <aside
    class="cart-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cart-title"
  >
    {/* Header bar */}
    <div class="cart-head">
      <h2 id="cart-title" class="cart-title">
        <span data-view="cart">YOUR CART</span>
        <span data-view="checkout">CHECKOUT</span>
        <span data-view="success">THANKS!</span>
      </h2>
      <button type="button" class="cart-close" aria-label="Close cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    {/* CART VIEW */}
    <section class="cart-body" data-view="cart">
      <ul class="cart-items"></ul>
      <p class="cart-empty">Cart's lookin' empty. Grab a tee.</p>

      <div class="cart-summary">
        <div class="cart-row">
          <span>Subtotal</span>
          <span data-total="subtotal">$0</span>
        </div>
        <div class="cart-row cart-row--mute">
          <span>Shipping</span>
          <span>Calculated next</span>
        </div>
        <button
          type="button"
          class="cart-cta"
          data-action="go-checkout"
          disabled
        >
          CHECKOUT
        </button>
        <p class="cart-error" data-cart-error hidden></p>
        <p class="cart-secure-note">
          Secure payment by Stripe. Shipping calculated at checkout.
        </p>
      </div>
    </section>

    {/* SUCCESS VIEW */}
    <section class="cart-body cart-body--success" data-view="success">
      <div class="cart-success">
        <div class="cart-success-mark" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </div>
        <h3>Order placed!</h3>
        <p class="cart-success-line">
          You're a real one. Your receipt is on its way to your inbox.
        </p>
        <button type="button" class="cart-cta" data-action="continue">
          KEEP SHOPPING
        </button>
      </div>
    </section>
  </aside>
</div>

<style is:global>
  /* ---------- shell ---------- */
  .cart-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    pointer-events: none;
  }
  .cart-overlay[data-state="open"] {
    pointer-events: auto;
  }
  .cart-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    border: 0;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 240ms var(--ease-out-strong);
  }
  .cart-overlay[data-state="open"] .cart-backdrop {
    opacity: 1;
  }
  .cart-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(440px, 92vw);
    background: #0a0a0a;
    color: #f5f5f5;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 320ms var(--ease-out-strong);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.5);
    will-change: transform;
  }
  .cart-overlay[data-state="open"] .cart-panel {
    transform: translateX(0);
  }

  /* ---------- header ---------- */
  .cart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .cart-title {
    font-family: var(--font-display);
    font-size: 26px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin: 0;
  }
  .cart-title > span { display: none; }
  .cart-overlay[data-view="cart"] .cart-title > span[data-view="cart"],
  .cart-overlay[data-view="checkout"] .cart-title > span[data-view="checkout"],
  .cart-overlay[data-view="success"] .cart-title > span[data-view="success"] {
    display: inline;
  }
  .cart-close {
    background: transparent;
    border: 0;
    color: #f5f5f5;
    cursor: pointer;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    transition: background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .cart-close:hover { background-color: rgba(255, 255, 255, 0.08); }
  .cart-close:active { transform: scale(0.92); }

  /* ---------- view switching ---------- */
  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 22px 28px;
    display: none;
  }
  .cart-overlay[data-view="cart"] .cart-body[data-view="cart"],
  .cart-overlay[data-view="checkout"] .cart-body[data-view="checkout"],
  .cart-overlay[data-view="success"] .cart-body[data-view="success"] {
    display: block;
  }

  /* ---------- cart list ---------- */
  .cart-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .cart-empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.55);
    padding: 32px 0;
    font-size: 14px;
  }
  .cart-overlay:not([data-empty="true"]) .cart-empty { display: none; }
  .cart-overlay[data-empty="true"] .cart-items { display: none; }

  .cart-item {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    animation: cart-slide-in 320ms var(--ease-out-strong);
  }
  @keyframes cart-slide-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .cart-item img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
  }
  .cart-item-info {
    min-width: 0;
  }
  .cart-item-name {
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0 0 2px;
    color: #f5f5f5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cart-item-price {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
  }
  .cart-qty {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    padding: 2px;
  }
  .cart-qty button {
    width: 24px;
    height: 24px;
    background: transparent;
    border: 0;
    color: #f5f5f5;
    cursor: pointer;
    border-radius: 3px;
    display: grid;
    place-items: center;
    font-size: 14px;
    line-height: 1;
    transition: background-color 140ms var(--ease-out-strong),
                transform 100ms var(--ease-out-strong);
  }
  .cart-qty button:hover { background: rgba(255, 255, 255, 0.1); }
  .cart-qty button:active { transform: scale(0.9); }
  .cart-qty span {
    min-width: 18px;
    text-align: center;
    font-size: 13px;
    font-variant-numeric: tabular-nums;
  }

  /* ---------- summary ---------- */
  .cart-summary {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cart-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
  }
  .cart-row--mute { color: rgba(255, 255, 255, 0.45); font-size: 12px; }
  .cart-row--total {
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 0.04em;
    color: #f5f5f5;
  }

  /* ---------- buttons ---------- */
  .cart-cta {
    margin-top: 14px;
    width: 100%;
    min-height: 48px;
    background: var(--color-accent);
    color: #000;
    border: 0;
    border-radius: 6px;
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.16em;
    cursor: pointer;
    transition: filter 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .cart-cta:hover { filter: brightness(1.08); }
  .cart-cta:active { transform: scale(0.98); }
  .cart-cta:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .cart-error {
    margin: 10px 0 0;
    font-size: 13px;
    color: #ff6b6b;
    text-align: center;
  }
  .cart-error[hidden] { display: none; }
  .cart-secure-note {
    margin: 10px 0 0;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.42);
    text-align: center;
  }
  .cart-back {
    margin-top: 10px;
    width: 100%;
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    cursor: pointer;
    padding: 8px;
    transition: color 140ms var(--ease-out-strong);
  }
  .cart-back:hover { color: var(--color-accent); }

  /* ---------- form ---------- */
  .cart-form fieldset {
    border: 0;
    padding: 0;
    margin: 0 0 20px;
  }
  .cart-form legend {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 10px;
  }
  .cart-pay-note {
    font-family: var(--font-sans);
    text-transform: none;
    letter-spacing: 0;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    font-weight: normal;
  }
  .cart-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
  }
  .cart-form input {
    width: 100%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #f5f5f5;
    border-radius: 5px;
    padding: 10px 12px;
    font-size: 14px;
    font-family: var(--font-sans);
    transition: border-color 140ms var(--ease-out-strong),
                background-color 140ms var(--ease-out-strong);
  }
  .cart-form input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.09);
  }
  .cart-form input.is-invalid {
    border-color: #ff5252;
    background: rgba(255, 82, 82, 0.08);
  }
  .cart-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .cart-form fieldset:nth-of-type(2) .cart-form-row {
    grid-template-columns: 1fr 80px 110px;
  }
  .cart-fill-dummy {
    margin-top: 6px;
    background: transparent;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.6);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 10px;
    border-radius: 4px;
    cursor: pointer;
    align-self: flex-start;
    transition: color 140ms var(--ease-out-strong),
                border-color 140ms var(--ease-out-strong);
  }
  .cart-fill-dummy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ---------- success ---------- */
  .cart-body--success { display: none; }
  .cart-overlay[data-view="success"] .cart-body--success { display: flex; flex-direction: column; }
  .cart-success {
    text-align: center;
    padding: 40px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .cart-success-mark {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #000;
    display: grid;
    place-items: center;
    margin-bottom: 6px;
    animation: cart-pop 480ms var(--ease-out-strong);
  }
  @keyframes cart-pop {
    from { opacity: 0; transform: scale(0.85); }
    to   { opacity: 1; transform: scale(1); }
  }
  .cart-success h3 {
    font-family: var(--font-display);
    font-size: 32px;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .cart-success-line {
    margin: 0;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
  }
  .cart-success-mute { color: rgba(255, 255, 255, 0.4); }
  .cart-success .cart-cta { max-width: 240px; margin-top: 18px; }

  @media (prefers-reduced-motion: reduce) {
    .cart-panel, .cart-backdrop, .cart-cta, .cart-close,
    .cart-qty button, .cart-form input, .cart-back, .cart-fill-dummy,
    .cart-item, .cart-success-mark {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  type CartItem = {
    id: string;
    productId: string;
    size: string;
    name: string;
    price: number;
    src: string;
    qty: number;
  };

  const STORAGE_KEY = "joedobo:cart:v2";

  const overlay = document.querySelector<HTMLElement>(".cart-overlay")!;
  const panel = overlay.querySelector<HTMLElement>(".cart-panel")!;
  const itemsEl = overlay.querySelector<HTMLElement>(".cart-items")!;
  const subtotalEls = overlay.querySelectorAll<HTMLElement>('[data-total="subtotal"]');
  const checkoutBtn = overlay.querySelector<HTMLButtonElement>('[data-action="go-checkout"]')!;
  const continueBtn = overlay.querySelector<HTMLButtonElement>('[data-action="continue"]')!;
  const closeBtn = overlay.querySelector<HTMLButtonElement>(".cart-close")!;
  const backdrop = overlay.querySelector<HTMLButtonElement>(".cart-backdrop")!;
  const errorEl = overlay.querySelector<HTMLElement>("[data-cart-error]")!;

  // ---------- state ----------
  const load = (): CartItem[] => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? (JSON.parse(raw) as CartItem[]) : [];
    } catch {
      return [];
    }
  };
  const save = (items: CartItem[]) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
    } catch {
      // private browsing or storage full — fail silently
    }
  };

  let items: CartItem[] = load();
  const fmt = (cents: number) =>
    (cents / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });

  const setView = (v: "cart" | "success") => {
    overlay.dataset.view = v;
  };
  const setOpen = (open: boolean) => {
    overlay.dataset.state = open ? "open" : "closed";
    overlay.setAttribute("aria-hidden", open ? "false" : "true");
    if (open) {
      // delay focus until the panel has slid in
      setTimeout(() => panel.querySelector<HTMLElement>(".cart-close")?.focus(), 100);
    }
  };

  const render = () => {
    overlay.dataset.empty = items.length === 0 ? "true" : "false";

    // List
    itemsEl.innerHTML = "";
    for (const it of items) {
      const li = document.createElement("li");
      li.className = "cart-item";
      li.innerHTML = `
        <img src="${it.src}" alt="" />
        <div class="cart-item-info">
          <p class="cart-item-name">${escapeHtml(it.name)}</p>
          <p class="cart-item-price">${fmt(it.price)} each</p>
        </div>
        <div class="cart-qty" role="group" aria-label="Quantity">
          <button type="button" data-act="dec" data-id="${it.id}" aria-label="Decrease">−</button>
          <span>${it.qty}</span>
          <button type="button" data-act="inc" data-id="${it.id}" aria-label="Increase">+</button>
        </div>
      `;
      itemsEl.appendChild(li);
    }

    // Totals
    const subtotal = items.reduce((s, i) => s + i.price * i.qty, 0);
    subtotalEls.forEach((el) => (el.textContent = fmt(subtotal)));

    // CTA enabled state
    checkoutBtn.disabled = items.length === 0;

    // Cart count badge in nav
    const count = items.reduce((s, i) => s + i.qty, 0);
    document.querySelectorAll<HTMLElement>("[data-cart-count]").forEach((el) => {
      el.textContent = String(count);
      el.dataset.empty = count === 0 ? "true" : "false";
    });

    save(items);
  };

  const escapeHtml = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

  const addItem = (p: Omit<CartItem, "qty">) => {
    const existing = items.find((i) => i.id === p.id);
    if (existing) existing.qty += 1;
    else items.push({ ...p, qty: 1 });
    render();
  };

  const showError = (msg: string) => {
    errorEl.textContent = msg;
    errorEl.hidden = false;
  };
  const clearError = () => {
    errorEl.hidden = true;
    errorEl.textContent = "";
  };

  const adjust = (id: string, delta: number) => {
    const it = items.find((i) => i.id === id);
    if (!it) return;
    it.qty += delta;
    if (it.qty <= 0) items = items.filter((i) => i.id !== id);
    render();
  };

  // ---------- events ----------
  window.addEventListener("cart:add", (e: Event) => {
    clearError();
    addItem((e as CustomEvent).detail);
    setView("cart");
    setOpen(true);
  });
  window.addEventListener("cart:open", () => {
    setView("cart");
    setOpen(true);
  });

  closeBtn.addEventListener("click", () => setOpen(false));
  backdrop.addEventListener("click", () => setOpen(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay.dataset.state === "open") setOpen(false);
  });

  itemsEl.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>("button[data-act]");
    if (!btn) return;
    adjust(btn.dataset.id!, btn.dataset.act === "inc" ? 1 : -1);
  });

  // Checkout → create a Stripe Checkout Session and redirect to it.
  checkoutBtn.addEventListener("click", async () => {
    if (items.length === 0) return;
    clearError();
    const label = checkoutBtn.textContent;
    checkoutBtn.disabled = true;
    checkoutBtn.textContent = "REDIRECTING…";
    try {
      const res = await fetch("/api/checkout", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          items: items.map((i) => ({ productId: i.productId, size: i.size, qty: i.qty })),
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.url) throw new Error(data.error || "Checkout failed.");
      window.location.href = data.url;
    } catch (err) {
      showError(err instanceof Error ? err.message : "Checkout failed. Please try again.");
      checkoutBtn.disabled = false;
      checkoutBtn.textContent = label;
    }
  });

  continueBtn.addEventListener("click", () => setOpen(false));

  // Returning from Stripe: ?checkout=success clears the cart and says thanks.
  const params = new URLSearchParams(window.location.search);
  const checkoutResult = params.get("checkout");
  if (checkoutResult === "success") {
    items = [];
    render();
    setView("success");
    setOpen(true);
  }
  if (checkoutResult) {
    params.delete("checkout");
    const q = params.toString();
    history.replaceState(
      {},
      "",
      window.location.pathname + (q ? `?${q}` : "") + window.location.hash,
    );
  }

  // initial paint (count badge etc.)
  render();
</script>
