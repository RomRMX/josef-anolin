---
// Cart + checkout + success flow. Static-site safe — payment is dummy.
// State lives in localStorage; events are window-level for loose coupling.
---

<div class="cart-overlay" data-state="closed" aria-hidden="true">
  <button
    type="button"
    class="cart-backdrop"
    aria-label="Close cart"
    tabindex="-1"
  ></button>

  <aside
    class="cart-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cart-title"
  >
    {/* Header bar */}
    <div class="cart-head">
      <h2 id="cart-title" class="cart-title">
        <span data-view="cart">YOUR CART</span>
        <span data-view="checkout">CHECKOUT</span>
        <span data-view="success">THANKS!</span>
      </h2>
      <button type="button" class="cart-close" aria-label="Close cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    {/* CART VIEW */}
    <section class="cart-body" data-view="cart">
      <ul class="cart-items"></ul>
      <p class="cart-empty">Cart's lookin' empty. Grab a tee.</p>

      <div class="cart-summary">
        <div class="cart-row">
          <span>Subtotal</span>
          <span data-total="subtotal">$0</span>
        </div>
        <div class="cart-row cart-row--mute">
          <span>Shipping</span>
          <span>Calculated next</span>
        </div>
        <button
          type="button"
          class="cart-cta"
          data-action="go-checkout"
          disabled
        >
          CHECKOUT
        </button>
      </div>
    </section>

    {/* CHECKOUT VIEW */}
    <section class="cart-body" data-view="checkout">
      <form class="cart-form" novalidate>
        <fieldset>
          <legend>Contact</legend>
          <label>
            <span>Email</span>
            <input type="email" name="email" required placeholder="you@email.com" autocomplete="email" />
          </label>
          <label>
            <span>Name</span>
            <input type="text" name="name" required placeholder="Jane Doe" autocomplete="name" />
          </label>
        </fieldset>

        <fieldset>
          <legend>Shipping</legend>
          <label>
            <span>Address</span>
            <input type="text" name="address" required placeholder="123 Main St" autocomplete="street-address" />
          </label>
          <div class="cart-form-row">
            <label>
              <span>City</span>
              <input type="text" name="city" required placeholder="Oakland" autocomplete="address-level2" />
            </label>
            <label>
              <span>State</span>
              <input type="text" name="state" required placeholder="CA" autocomplete="address-level1" maxlength="2" />
            </label>
            <label>
              <span>Zip</span>
              <input type="text" name="zip" required placeholder="94601" autocomplete="postal-code" inputmode="numeric" />
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Payment <span class="cart-pay-note">— dummy, no charge</span></legend>
          <label>
            <span>Card number</span>
            <input
              type="text"
              name="card"
              required
              placeholder="4242 4242 4242 4242"
              inputmode="numeric"
              autocomplete="cc-number"
            />
          </label>
          <div class="cart-form-row">
            <label>
              <span>Expiry</span>
              <input type="text" name="expiry" required placeholder="MM/YY" autocomplete="cc-exp" />
            </label>
            <label>
              <span>CVC</span>
              <input type="text" name="cvc" required placeholder="123" inputmode="numeric" autocomplete="cc-csc" />
            </label>
          </div>
          <button
            type="button"
            class="cart-fill-dummy"
            data-action="fill-dummy"
          >
            Fill dummy info
          </button>
        </fieldset>

        <div class="cart-summary">
          <div class="cart-row">
            <span>Subtotal</span>
            <span data-total="subtotal">$0</span>
          </div>
          <div class="cart-row">
            <span>Shipping (flat)</span>
            <span>$5</span>
          </div>
          <div class="cart-row cart-row--total">
            <span>Total</span>
            <span data-total="grand">$0</span>
          </div>
          <button type="submit" class="cart-cta">
            PLACE ORDER
          </button>
          <button
            type="button"
            class="cart-back"
            data-action="back-to-cart"
          >
            ← Back to cart
          </button>
        </div>
      </form>
    </section>

    {/* SUCCESS VIEW */}
    <section class="cart-body cart-body--success" data-view="success">
      <div class="cart-success">
        <div class="cart-success-mark" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </div>
        <h3>Order placed!</h3>
        <p class="cart-success-line">
          You're a real one. A receipt's heading to <strong data-success="email">your inbox</strong>.
        </p>
        <p class="cart-success-line cart-success-mute">
          Order <span data-success="orderId">#JOE-0000</span>
        </p>
        <button type="button" class="cart-cta" data-action="continue">
          KEEP SHOPPING
        </button>
      </div>
    </section>
  </aside>
</div>

<style is:global>
  /* ---------- shell ---------- */
  .cart-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    pointer-events: none;
  }
  .cart-overlay[data-state="open"] {
    pointer-events: auto;
  }
  .cart-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    border: 0;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 240ms var(--ease-out-strong);
  }
  .cart-overlay[data-state="open"] .cart-backdrop {
    opacity: 1;
  }
  .cart-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(440px, 92vw);
    background: #0a0a0a;
    color: #f5f5f5;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 320ms var(--ease-out-strong);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.5);
    will-change: transform;
  }
  .cart-overlay[data-state="open"] .cart-panel {
    transform: translateX(0);
  }

  /* ---------- header ---------- */
  .cart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .cart-title {
    font-family: var(--font-display);
    font-size: 26px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin: 0;
  }
  .cart-title > span { display: none; }
  .cart-overlay[data-view="cart"] .cart-title > span[data-view="cart"],
  .cart-overlay[data-view="checkout"] .cart-title > span[data-view="checkout"],
  .cart-overlay[data-view="success"] .cart-title > span[data-view="success"] {
    display: inline;
  }
  .cart-close {
    background: transparent;
    border: 0;
    color: #f5f5f5;
    cursor: pointer;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    transition: background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .cart-close:hover { background-color: rgba(255, 255, 255, 0.08); }
  .cart-close:active { transform: scale(0.92); }

  /* ---------- view switching ---------- */
  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 22px 28px;
    display: none;
  }
  .cart-overlay[data-view="cart"] .cart-body[data-view="cart"],
  .cart-overlay[data-view="checkout"] .cart-body[data-view="checkout"],
  .cart-overlay[data-view="success"] .cart-body[data-view="success"] {
    display: block;
  }

  /* ---------- cart list ---------- */
  .cart-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .cart-empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.55);
    padding: 32px 0;
    font-size: 14px;
  }
  .cart-overlay:not([data-empty="true"]) .cart-empty { display: none; }
  .cart-overlay[data-empty="true"] .cart-items { display: none; }

  .cart-item {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    animation: cart-slide-in 320ms var(--ease-out-strong);
  }
  @keyframes cart-slide-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .cart-item img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
  }
  .cart-item-info {
    min-width: 0;
  }
  .cart-item-name {
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0 0 2px;
    color: #f5f5f5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cart-item-price {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
  }
  .cart-qty {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    padding: 2px;
  }
  .cart-qty button {
    width: 24px;
    height: 24px;
    background: transparent;
    border: 0;
    color: #f5f5f5;
    cursor: pointer;
    border-radius: 3px;
    display: grid;
    place-items: center;
    font-size: 14px;
    line-height: 1;
    transition: background-color 140ms var(--ease-out-strong),
                transform 100ms var(--ease-out-strong);
  }
  .cart-qty button:hover { background: rgba(255, 255, 255, 0.1); }
  .cart-qty button:active { transform: scale(0.9); }
  .cart-qty span {
    min-width: 18px;
    text-align: center;
    font-size: 13px;
    font-variant-numeric: tabular-nums;
  }

  /* ---------- summary ---------- */
  .cart-summary {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cart-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
  }
  .cart-row--mute { color: rgba(255, 255, 255, 0.45); font-size: 12px; }
  .cart-row--total {
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 0.04em;
    color: #f5f5f5;
  }

  /* ---------- buttons ---------- */
  .cart-cta {
    margin-top: 14px;
    width: 100%;
    min-height: 48px;
    background: var(--color-accent);
    color: #000;
    border: 0;
    border-radius: 6px;
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.16em;
    cursor: pointer;
    transition: filter 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .cart-cta:hover { filter: brightness(1.08); }
  .cart-cta:active { transform: scale(0.98); }
  .cart-cta:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .cart-back {
    margin-top: 10px;
    width: 100%;
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    cursor: pointer;
    padding: 8px;
    transition: color 140ms var(--ease-out-strong);
  }
  .cart-back:hover { color: var(--color-accent); }

  /* ---------- form ---------- */
  .cart-form fieldset {
    border: 0;
    padding: 0;
    margin: 0 0 20px;
  }
  .cart-form legend {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 10px;
  }
  .cart-pay-note {
    font-family: var(--font-sans);
    text-transform: none;
    letter-spacing: 0;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    font-weight: normal;
  }
  .cart-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
  }
  .cart-form input {
    width: 100%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #f5f5f5;
    border-radius: 5px;
    padding: 10px 12px;
    font-size: 14px;
    font-family: var(--font-sans);
    transition: border-color 140ms var(--ease-out-strong),
                background-color 140ms var(--ease-out-strong);
  }
  .cart-form input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.09);
  }
  .cart-form input.is-invalid {
    border-color: #ff5252;
    background: rgba(255, 82, 82, 0.08);
  }
  .cart-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .cart-form fieldset:nth-of-type(2) .cart-form-row {
    grid-template-columns: 1fr 80px 110px;
  }
  .cart-fill-dummy {
    margin-top: 6px;
    background: transparent;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.6);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 10px;
    border-radius: 4px;
    cursor: pointer;
    align-self: flex-start;
    transition: color 140ms var(--ease-out-strong),
                border-color 140ms var(--ease-out-strong);
  }
  .cart-fill-dummy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ---------- success ---------- */
  .cart-body--success { display: none; }
  .cart-overlay[data-view="success"] .cart-body--success { display: flex; flex-direction: column; }
  .cart-success {
    text-align: center;
    padding: 40px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .cart-success-mark {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #000;
    display: grid;
    place-items: center;
    margin-bottom: 6px;
    animation: cart-pop 480ms var(--ease-out-strong);
  }
  @keyframes cart-pop {
    from { opacity: 0; transform: scale(0.85); }
    to   { opacity: 1; transform: scale(1); }
  }
  .cart-success h3 {
    font-family: var(--font-display);
    font-size: 32px;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .cart-success-line {
    margin: 0;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
  }
  .cart-success-mute { color: rgba(255, 255, 255, 0.4); }
  .cart-success .cart-cta { max-width: 240px; margin-top: 18px; }

  @media (prefers-reduced-motion: reduce) {
    .cart-panel, .cart-backdrop, .cart-cta, .cart-close,
    .cart-qty button, .cart-form input, .cart-back, .cart-fill-dummy,
    .cart-item, .cart-success-mark {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  type CartItem = {
    id: string;
    name: string;
    price: number;
    src: string;
    qty: number;
  };

  const STORAGE_KEY = "joedobo:cart:v1";

  const overlay = document.querySelector<HTMLElement>(".cart-overlay")!;
  const panel = overlay.querySelector<HTMLElement>(".cart-panel")!;
  const itemsEl = overlay.querySelector<HTMLElement>(".cart-items")!;
  const subtotalEls = overlay.querySelectorAll<HTMLElement>('[data-total="subtotal"]');
  const grandEl = overlay.querySelector<HTMLElement>('[data-total="grand"]');
  const checkoutBtn = overlay.querySelector<HTMLButtonElement>('[data-action="go-checkout"]')!;
  const backBtn = overlay.querySelector<HTMLButtonElement>('[data-action="back-to-cart"]')!;
  const continueBtn = overlay.querySelector<HTMLButtonElement>('[data-action="continue"]')!;
  const fillDummyBtn = overlay.querySelector<HTMLButtonElement>('[data-action="fill-dummy"]')!;
  const closeBtn = overlay.querySelector<HTMLButtonElement>(".cart-close")!;
  const backdrop = overlay.querySelector<HTMLButtonElement>(".cart-backdrop")!;
  const form = overlay.querySelector<HTMLFormElement>(".cart-form")!;

  // ---------- state ----------
  const load = (): CartItem[] => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? (JSON.parse(raw) as CartItem[]) : [];
    } catch {
      return [];
    }
  };
  const save = (items: CartItem[]) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
    } catch {
      // private browsing or storage full — fail silently
    }
  };

  let items: CartItem[] = load();
  const fmt = (cents: number) =>
    (cents / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });

  const SHIPPING_CENTS = 500;

  const setView = (v: "cart" | "checkout" | "success") => {
    overlay.dataset.view = v;
  };
  const setOpen = (open: boolean) => {
    overlay.dataset.state = open ? "open" : "closed";
    overlay.setAttribute("aria-hidden", open ? "false" : "true");
    if (open) {
      // delay focus until the panel has slid in
      setTimeout(() => panel.querySelector<HTMLElement>(".cart-close")?.focus(), 100);
    }
  };

  const render = () => {
    overlay.dataset.empty = items.length === 0 ? "true" : "false";

    // List
    itemsEl.innerHTML = "";
    for (const it of items) {
      const li = document.createElement("li");
      li.className = "cart-item";
      li.innerHTML = `
        <img src="${it.src}" alt="" />
        <div class="cart-item-info">
          <p class="cart-item-name">${escapeHtml(it.name)}</p>
          <p class="cart-item-price">${fmt(it.price)} each</p>
        </div>
        <div class="cart-qty" role="group" aria-label="Quantity">
          <button type="button" data-act="dec" data-id="${it.id}" aria-label="Decrease">−</button>
          <span>${it.qty}</span>
          <button type="button" data-act="inc" data-id="${it.id}" aria-label="Increase">+</button>
        </div>
      `;
      itemsEl.appendChild(li);
    }

    // Totals
    const subtotal = items.reduce((s, i) => s + i.price * i.qty, 0);
    subtotalEls.forEach((el) => (el.textContent = fmt(subtotal)));
    if (grandEl) grandEl.textContent = fmt(subtotal + (items.length ? SHIPPING_CENTS : 0));

    // CTA enabled state
    checkoutBtn.disabled = items.length === 0;

    // Cart count badge in nav
    const count = items.reduce((s, i) => s + i.qty, 0);
    document.querySelectorAll<HTMLElement>("[data-cart-count]").forEach((el) => {
      el.textContent = String(count);
      el.dataset.empty = count === 0 ? "true" : "false";
    });

    save(items);
  };

  const escapeHtml = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

  const addItem = (p: { id: string; name: string; price: number; src: string }) => {
    const existing = items.find((i) => i.id === p.id);
    if (existing) existing.qty += 1;
    else items.push({ ...p, qty: 1 });
    render();
  };

  const adjust = (id: string, delta: number) => {
    const it = items.find((i) => i.id === id);
    if (!it) return;
    it.qty += delta;
    if (it.qty <= 0) items = items.filter((i) => i.id !== id);
    render();
  };

  // ---------- events ----------
  window.addEventListener("cart:add", (e: Event) => {
    const detail = (e as CustomEvent).detail;
    addItem(detail);
    setOpen(true);
    setView("cart");
    // brief pulse on the originating button
    const btn = document.querySelector<HTMLButtonElement>(
      `.add-to-cart-btn[data-product-id="${detail.id}"]`
    );
    if (btn) {
      btn.classList.add("is-added");
      setTimeout(() => btn.classList.remove("is-added"), 600);
    }
  });
  window.addEventListener("cart:open", () => {
    setView("cart");
    setOpen(true);
  });

  closeBtn.addEventListener("click", () => setOpen(false));
  backdrop.addEventListener("click", () => setOpen(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay.dataset.state === "open") setOpen(false);
  });

  itemsEl.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>("button[data-act]");
    if (!btn) return;
    const id = btn.dataset.id!;
    adjust(id, btn.dataset.act === "inc" ? 1 : -1);
  });

  checkoutBtn.addEventListener("click", () => {
    if (items.length === 0) return;
    setView("checkout");
  });
  backBtn.addEventListener("click", () => setView("cart"));
  continueBtn.addEventListener("click", () => setOpen(false));

  fillDummyBtn.addEventListener("click", () => {
    const dummy: Record<string, string> = {
      email: "joe@dobo.test",
      name: "Joe Dobo",
      address: "1984 Somewhere Ave",
      city: "Oakland",
      state: "CA",
      zip: "94601",
      card: "4242 4242 4242 4242",
      expiry: "12/29",
      cvc: "123",
    };
    for (const [name, value] of Object.entries(dummy)) {
      const input = form.querySelector<HTMLInputElement>(`[name="${name}"]`);
      if (input) {
        input.value = value;
        input.classList.remove("is-invalid");
      }
    }
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    // Lightweight inline validation — flag empty required fields
    let firstInvalid: HTMLInputElement | null = null;
    form.querySelectorAll<HTMLInputElement>("input[required]").forEach((input) => {
      if (!input.value.trim()) {
        input.classList.add("is-invalid");
        if (!firstInvalid) firstInvalid = input;
      } else {
        input.classList.remove("is-invalid");
      }
    });
    if (firstInvalid) {
      firstInvalid.focus();
      return;
    }

    const email = (form.elements.namedItem("email") as HTMLInputElement).value.trim();
    const orderId = `JOE-${String(Math.floor(Math.random() * 9000) + 1000)}`;
    const emailEl = overlay.querySelector<HTMLElement>('[data-success="email"]');
    const orderIdEl = overlay.querySelector<HTMLElement>('[data-success="orderId"]');
    if (emailEl) emailEl.textContent = email;
    if (orderIdEl) orderIdEl.textContent = `#${orderId}`;

    // Clear cart on successful "order"
    items = [];
    render();
    form.reset();
    setView("success");
  });

  // initial paint (count badge etc.)
  render();
</script>
