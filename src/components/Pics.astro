---
const pics: string[] = Array.from(
  { length: 20 },
  (_, i) => `/pics/joe-${String(i + 1).padStart(2, "0")}.webp`,
);
---

<div id="pics">
  <h2 class="section-h2 section-h2--sub">PICTURES</h2>
  <div class="pics-grid">
    {pics.map((src, i) => (
      <a
        href={src}
        target="_blank"
        rel="noopener noreferrer"
        class="pic-tile"
      >
        <img
          src={src}
          alt={`Josef Anolin photo ${i + 1}`}
          loading="lazy"
        />
      </a>
    ))}
  </div>
</div>

<style>
  .pics-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.5rem;
  }
  .pic-tile {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-panel);
  }
  .pic-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms var(--ease-out-strong);
  }
  .pic-tile:hover img { transform: scale(1.06); }

  @media (max-width: 767px) {
    .pics-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
</style>
