---
const pics: string[] = Array.from(
  { length: 20 },
  (_, i) => `/pics/joe-${String(i + 1).padStart(2, "0")}.webp`,
);
---

<div id="pics">
  <h2 class="section-h2 section-h2--sub">PHOTOS</h2>
  <div class="pics-grid">
    {pics.map((src, i) => (
      <a
        href={src}
        target="_blank"
        rel="noopener noreferrer"
        class="pic-tile"
      >
        <img
          src={src}
          alt={`Josef Anolin photo ${i + 1}`}
          loading="lazy"
        />
      </a>
    ))}
  </div>
</div>

<style>
  /* Extra gap so PHOTOS sits well clear of the VIDEOS block above. */
  #pics .section-h2--sub {
    margin-top: 7rem;
  }
  /* 3 fixed rows; photos flow top-to-bottom into columns and overflow
     horizontally. Same thumbnail size as the old 3-up grid; the extra
     columns scroll sideways with the scrollbar hidden (wheel-scroll on
     hover via the script below). */
  .pics-grid {
    --pic-size: 190px;
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(3, var(--pic-size));
    grid-auto-columns: var(--pic-size);
    gap: 0.6rem;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* legacy Edge */
  }
  .pics-grid::-webkit-scrollbar { display: none; } /* Chromium / Safari */
  .pic-tile {
    display: block;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-panel);
  }
  .pic-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms var(--ease-out-strong);
  }
  .pic-tile:hover img { transform: scale(1.06); }

  @media (max-width: 899px) {
    .pics-grid { --pic-size: 150px; }
  }
</style>

<script>
  // Hover-scroll: translate a vertical wheel into horizontal scrolling while
  // the cursor is over the photo strip, but let the page scroll at the ends.
  const grid = document.querySelector<HTMLElement>(".pics-grid");
  if (grid) {
    grid.addEventListener(
      "wheel",
      (e) => {
        if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
        const max = grid.scrollWidth - grid.clientWidth;
        const atStart = grid.scrollLeft <= 0;
        const atEnd = grid.scrollLeft >= max - 1;
        if ((e.deltaY < 0 && !atStart) || (e.deltaY > 0 && !atEnd)) {
          e.preventDefault();
          grid.scrollLeft += e.deltaY;
        }
      },
      { passive: false },
    );
  }
</script>
