---
type Video = { id: string; title?: string };

const videos: Video[] = [
  { id: "Is2_LT5YVww" },
  { id: "1shEtqNu1Ms", title: "Counting Farsees with Josef Anolin" },
  { id: "_PWBWs5rL94" },
  { id: "PfS_FJM735U" },
  { id: "W4qgq3mXbgI" },
  { id: "q1iKMftySOA" },
];
---

<div id="videos">
  <h2 class="section-h2">VIDEOS</h2>
  <div class="videos-grid">
    {videos.map((v) => (
      <button
        type="button"
        class="yt-facade"
        data-yt-id={v.id}
        aria-label={v.title ? `Play: ${v.title}` : "Play video"}
      >
        <img
          src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
          alt={v.title ?? ""}
          loading="lazy"
          class="yt-thumb"
        />
        <span class="yt-play" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
        {v.title && <span class="yt-caption">{v.title}</span>}
      </button>
    ))}
  </div>
</div>

<style>
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }
  .yt-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 6px;
    background: #000;
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .yt-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms var(--ease-out-strong);
  }
  .yt-facade:hover .yt-thumb { transform: scale(1.05); }
  .yt-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    transition: background-color 160ms var(--ease-out-strong);
  }
  .yt-facade:hover .yt-play { background: #c4302b; }
  .yt-caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 0.4rem 0.5rem;
    font-size: 0.7rem;
    line-height: 1.2;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85), transparent);
    text-align: left;
  }

  @media (max-width: 767px) {
    .videos-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".yt-facade").forEach((btn) => {
    btn.addEventListener(
      "click",
      () => {
        const id = btn.dataset.ytId;
        if (!id) return;
        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = btn.getAttribute("aria-label") ?? "YouTube video";
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.style.cssText =
          "position:absolute;inset:0;width:100%;height:100%;border:0;";
        btn.replaceChildren(iframe);
        btn.disabled = true;
      },
      { once: true },
    );
  });
</script>
