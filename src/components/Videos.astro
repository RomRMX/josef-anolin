---
// TODO: replace these with real Instagram reel permalinks (e.g. https://www.instagram.com/reel/<id>/)
const reels: string[] = [];
const placeholders = [0, 1, 2];
---

<section
  id="videos"
  class="max-w-6xl mx-auto px-6 py-6 scroll-mt-24 grid grid-cols-1 md:grid-cols-[minmax(180px,1fr)_3fr] gap-4 md:gap-12 items-start"
>
  <h2
    class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide"
  >
    VIDEOS
  </h2>

  {
    reels.length === 0 ? (
      <div class="grid grid-cols-3 gap-3 md:gap-4">
        {placeholders.map(() => (
          <div class="aspect-[4/3] rounded-md bg-[color:var(--color-panel)]/60" />
        ))}
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {reels.map((url) => (
            <blockquote
              class="instagram-media bg-neutral-900 rounded-lg overflow-hidden"
              data-instgrm-captioned
              data-instgrm-permalink={url}
              data-instgrm-version="14"
              style="margin: 0; min-width: 0; width: 100%;"
            />
          ))}
        </div>
        <script async src="https://www.instagram.com/embed.js" />
      </>
    )
  }
</section>
