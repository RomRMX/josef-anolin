---
type Video = { id: string; title?: string };

// YouTube videos + Shorts. Short URLs (`/shorts/<id>`) and full URLs both
// work — only the 11-char video ID matters for the embed and thumbnail.
const videos: Video[] = [
  { id: "Is2_LT5YVww" },
  { id: "1shEtqNu1Ms", title: "Counting Farsees with Josef Anolin" },
  { id: "_PWBWs5rL94" },
  { id: "PfS_FJM735U" },
  { id: "W4qgq3mXbgI" },
  { id: "q1iKMftySOA" },
];
---

<section
  id="videos"
  class="max-w-6xl mx-auto px-6 py-6 scroll-mt-24 grid grid-cols-1 md:grid-cols-[minmax(280px,1fr)_3fr] gap-4 md:gap-12 items-start"
>
  <h2
    class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide md:text-right text-black"
  >
    VIDEOS
  </h2>

  {/* Horizontal scrolling row — all 6 videos visible by swipe (mobile) or
      drag/scroll (desktop). One row keeps the section compact so PICS
      below still has space to breathe inside the same 100dvh card. */}
  <div class="videos-track -mx-6 px-6 overflow-x-auto overflow-y-hidden">
    <div class="flex gap-3 md:gap-4 w-max pb-2">
      {
        videos.map((v) => (
          <button
            type="button"
            class="yt-facade group relative block shrink-0 w-[200px] md:w-[260px] aspect-video overflow-hidden rounded-md bg-black"
            data-yt-id={v.id}
            aria-label={v.title ? `Play: ${v.title}` : "Play video"}
          >
            <img
              src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
              alt={v.title ?? ""}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
            <span class="pointer-events-none absolute inset-0 grid place-items-center">
              <span
                class="grid place-items-center w-12 h-12 rounded-full bg-black/70 group-hover:bg-red-600 transition-colors"
                aria-hidden="true"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white translate-x-[1px]"
                >
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </span>
            {v.title && (
              <span class="pointer-events-none absolute bottom-0 inset-x-0 px-2 py-1.5 text-[11px] leading-tight text-white bg-gradient-to-t from-black/80 to-transparent">
                {v.title}
              </span>
            )}
          </button>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Hide horizontal scrollbar but keep scrolling functional. */
  .videos-track {
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .videos-track::-webkit-scrollbar { display: none; }
</style>

<script>
  // Swap the thumbnail facade for a real YouTube iframe on click.
  document.querySelectorAll<HTMLButtonElement>(".yt-facade").forEach((btn) => {
    btn.addEventListener(
      "click",
      () => {
        const id = btn.dataset.ytId;
        if (!id) return;
        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = btn.getAttribute("aria-label") ?? "YouTube video";
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.className = "absolute inset-0 w-full h-full border-0";
        // Replace facade contents with the iframe; disable further clicks.
        btn.replaceChildren(iframe);
        btn.disabled = true;
        btn.classList.remove("group");
      },
      { once: true },
    );
  });
</script>
