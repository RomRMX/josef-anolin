---
const links = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "CONTACT" },
];
---

{/* Floating pill nav. Fixed (not sticky) so it stays above the sticky deck.
    Z-50 keeps it over every card. The deck snaps the page back to scrollY 0
    on the loop, so this must remain above all stacking contexts. */}
<header
  class="fixed top-3 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-1.5rem)] max-w-3xl pointer-events-none"
>
  <div
    class="pointer-events-auto flex items-center justify-between gap-3 px-4 md:px-6 py-2.5 md:py-3 bg-black/85 backdrop-blur-md backdrop-saturate-150 rounded-full shadow-[0_8px_28px_rgba(0,0,0,0.35)]"
  >
    <a
      href="#"
      aria-label="Josef Anolin — back to top"
      class="shrink-0 text-[12px] md:text-sm font-bold tracking-[0.18em] text-[color:var(--color-accent)] hover:text-white transition-colors"
    >
      JOSEF&nbsp;ANOLIN
    </a>
    <nav
      class="flex items-center gap-3 md:gap-6 text-[10px] md:text-[12px] font-semibold tracking-[0.18em]"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-neutral-300 hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
