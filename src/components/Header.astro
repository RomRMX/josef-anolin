---
const links = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "CONTACT" },
];

const socials = [
  { label: "Email", href: "mailto:josefanolin@gmail.com", icon: "/socials/social__0005_Layer-3.png" },
  { label: "Instagram", href: "https://www.instagram.com/comedianjoe510/", icon: "/socials/social__0003_Layer-5.png" },
  { label: "TikTok", href: "https://www.tiktok.com/@comedianjoe510?is_from_webapp=1&sender_device=pc", icon: "/socials/social__0002_Layer-6.png" },
  { label: "YouTube", href: "https://www.youtube.com/@comedianjoe510", icon: "/socials/social__0000_Layer-8.png" },
  { label: "Facebook", href: "https://www.facebook.com/JosefAnolinComedian", icon: "/socials/social__0004_Layer-4.png" },
  { label: "Threads", href: "https://www.threads.com/@comedianjoe510", icon: "/socials/social__0001_Layer-7.png" },
];
---

{/* MOBILE header — logo row with cart button on the right, then nav links. */}
<header class="site-header md:hidden fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a] backdrop-blur-md backdrop-saturate-150">
  <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col items-stretch gap-2">
    <div class="flex items-center justify-between">
      <span class="w-[34px]" aria-hidden="true"></span>
      <a href="#" aria-label="Josef Anolin — back to top" class="block">
        <img
          src="/joedobo_straightlogo.png"
          alt="Josef Anolin"
          class="h-[18px] w-auto select-none pointer-events-none"
        />
      </a>
      <button type="button" class="cart-trigger cart-trigger--mobile" aria-label="Open cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-count" data-cart-count data-empty="true">0</span>
      </button>
    </div>
    <nav
      class="flex items-center justify-center gap-5 text-[12px] font-semibold tracking-[0.18em]"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-white hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

{/* DESKTOP header — logo left, nav center, HIT ME! socials right. Hidden on hero
    card; revealed once the user scrolls past the first viewport. */}
<header class="site-header-desktop hidden md:block fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a]/95 backdrop-blur-md backdrop-saturate-150 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center gap-6">
    <a href="#" aria-label="Josef Anolin — back to top" class="shrink-0">
      <img
        src="/joedobo_straightlogo.png"
        alt="Josef Anolin"
        class="h-[26px] w-auto select-none pointer-events-none"
      />
    </a>
    <nav
      class="flex items-center gap-7 text-[13px] font-semibold tracking-[0.18em]"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-white hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="ml-auto flex items-center gap-3">
      <span
        class="font-[family-name:var(--font-display)] text-[color:var(--color-accent)] text-xl tracking-wide"
      >
        HIT ME!
      </span>
      <ul class="flex items-center gap-2">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.href.startsWith("http") ? "_blank" : undefined}
                rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
                aria-label={s.label}
                title={s.label}
                class="hit-icon-link inline-flex items-center justify-center w-8 h-8 rounded-sm"
              >
                <img
                  src={s.icon}
                  alt=""
                  class="w-6 h-6 select-none pointer-events-none"
                />
              </a>
            </li>
          ))
        }
      </ul>
      <button type="button" class="cart-trigger" aria-label="Open cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-count" data-cart-count data-empty="true">0</span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header-desktop {
    transform: translateY(-100%);
    transition: transform 280ms var(--ease-out-strong);
    will-change: transform;
  }
  .site-header-desktop.is-visible {
    transform: translateY(0);
  }
  /* Press feedback for any interactive element inside either header. */
  .site-header a,
  .site-header-desktop a {
    transition: color 160ms var(--ease-out-strong),
                background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .site-header a:active,
  .site-header-desktop a:active {
    transform: scale(0.97);
  }

  /* HIT ME! icon links — subtle hover lift. */
  .hit-icon-link {
    transition: background-color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .hit-icon-link:hover {
    background-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }
  .hit-icon-link:active {
    transform: scale(0.94);
  }

  /* Cart trigger button — shared between mobile + desktop headers. */
  .cart-trigger {
    position: relative;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 160ms var(--ease-out-strong),
                border-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
    margin-left: 4px;
  }
  .cart-trigger:hover {
    background-color: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  .cart-trigger:active { transform: scale(0.94); }
  .cart-trigger--mobile {
    width: 34px;
    height: 34px;
  }
  .cart-count {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 999px;
    background: var(--color-accent);
    color: #000;
    font-size: 10px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    display: grid;
    place-items: center;
    line-height: 1;
    border: 2px solid #0a0a0a;
    transition: opacity 200ms var(--ease-out-strong),
                transform 240ms var(--ease-out-strong);
  }
  .cart-count[data-empty="true"] {
    opacity: 0;
    transform: scale(0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header-desktop,
    .site-header a,
    .site-header-desktop a,
    .cart-trigger,
    .cart-count {
      transition: none;
    }
    .site-header a:active,
    .site-header-desktop a:active,
    .cart-trigger:active {
      transform: none;
    }
  }
</style>

<script>
  // Show the desktop header after the hero card scrolls past the top.
  const header = document.querySelector<HTMLElement>(".site-header-desktop");
  if (header) {
    const update = () => {
      // Roughly: hide while still on the hero card (first viewport-height of scroll).
      const visible = window.scrollY > window.innerHeight * 0.6;
      header.classList.toggle("is-visible", visible);
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
  }

  // Cart trigger — open the drawer.
  document.querySelectorAll<HTMLButtonElement>(".cart-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("cart:open"));
    });
  });
</script>
