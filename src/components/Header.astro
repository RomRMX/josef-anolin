---
const links = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "CONTACT" },
];
---

{/* Full-width fixed header. Two rows: brand on top, nav on bottom.
    Stays above the sticky deck via z-50; bg-black/90 with backdrop-blur
    keeps the deck visible behind it without losing legibility. */}
<header class="md:hidden fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-md backdrop-saturate-150">
  <div class="max-w-6xl mx-auto px-5 py-3 flex flex-col items-center gap-2">
    <a
      href="#"
      aria-label="Josef Anolin — back to top"
      class="block"
    >
      <img
        src="/joedobo_straightlogo.png"
        alt="Josef Anolin"
        class="h-[18px] w-auto select-none pointer-events-none"
      />
    </a>
    <nav
      class="flex items-center justify-center gap-5 text-[12px] font-semibold tracking-[0.18em]"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-white hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
