---
const links = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "HIT ME UP" },
];
---

{/* MOBILE header — logo row with cart button on the right, then nav links. */}
<header class="site-header min-[900px]:hidden fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a] backdrop-blur-md backdrop-saturate-150">
  <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col items-stretch gap-2">
    <div class="flex items-center justify-between">
      <span class="w-[34px]" aria-hidden="true"></span>
      <a href="#" aria-label="Josef Anolin — back to top" class="block">
        <img
          src="/joedobo_straightlogo.png"
          alt="Josef Anolin"
          class="h-[41px] w-auto select-none pointer-events-none"
        />
      </a>
      <button type="button" class="cart-trigger cart-trigger--mobile" aria-label="Open cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-count" data-cart-count data-empty="true">0</span>
      </button>
    </div>
    <nav
      class="flex items-center justify-center gap-5 text-[12px] font-semibold tracking-[0.18em]"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-white hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

{/* DESKTOP / TABLET cart — at >=900px the hero rail owns the nav and there's
    no header bar, so the cart lives as a fixed button in the top-right. */}
<button
  type="button"
  class="cart-trigger cart-trigger--desktop"
  aria-label="Open cart"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
    <path d="M3 6h18" />
    <path d="M16 10a4 4 0 0 1-8 0" />
  </svg>
  <span class="cart-count" data-cart-count data-empty="true">0</span>
</button>

<style>
  /* Press feedback for links in the mobile header. */
  .site-header a {
    transition: color 160ms var(--ease-out-strong),
                background-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
  }
  .site-header a:active {
    transform: scale(0.97);
  }

  /* Cart trigger button — shared by the mobile header cart and the fixed
     desktop/tablet cart button. */
  .cart-trigger {
    position: relative;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 160ms var(--ease-out-strong),
                border-color 160ms var(--ease-out-strong),
                transform 120ms var(--ease-out-strong);
    margin-left: 4px;
  }
  .cart-trigger:hover {
    background-color: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  .cart-trigger:active { transform: scale(0.94); }
  .cart-trigger--mobile {
    width: 34px;
    height: 34px;
  }
  /* Desktop/tablet (>=900px): fixed cart button, top-right of the viewport. */
  .cart-trigger--desktop {
    display: none;
    position: fixed;
    top: 18px;
    right: 24px;
    z-index: 50;
    width: 40px;
    height: 40px;
    margin-left: 0;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(8px);
  }
  @media (min-width: 900px) {
    .cart-trigger--desktop { display: grid; }
  }
  .cart-count {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 999px;
    background: var(--color-accent);
    color: #000;
    font-size: 10px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    display: grid;
    place-items: center;
    line-height: 1;
    border: 2px solid #0a0a0a;
    transition: opacity 200ms var(--ease-out-strong),
                transform 240ms var(--ease-out-strong);
  }
  .cart-count[data-empty="true"] {
    opacity: 0;
    transform: scale(0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header a,
    .cart-trigger,
    .cart-count {
      transition: none;
    }
    .site-header a:active,
    .cart-trigger:active {
      transform: none;
    }
  }
</style>

<script>
  // Cart trigger — open the drawer.
  document.querySelectorAll<HTMLButtonElement>(".cart-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("cart:open"));
    });
  });
</script>
