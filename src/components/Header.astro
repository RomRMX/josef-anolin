---
const links = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "CONTACT" },
];
---

<header
  class="sticky top-0 z-50 backdrop-blur-xl backdrop-saturate-150 bg-white/[0.04] border-b border-white/10 shadow-[0_1px_0_0_rgba(255,255,255,0.06)_inset,0_8px_24px_-12px_rgba(0,0,0,0.6)]"
>
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-3 md:py-4 flex items-center justify-between gap-4">
    <a
      href="#top"
      class="hidden md:inline text-sm font-bold tracking-widest text-[color:var(--color-accent)]"
    >
      JOSEF&nbsp;ANOLIN
    </a>
    <nav
      class="flex w-full md:w-auto justify-between md:justify-end items-center gap-3 md:gap-7 text-[11px] md:text-[13px] font-semibold tracking-widest"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-neutral-300 hover:text-[color:var(--color-accent)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
