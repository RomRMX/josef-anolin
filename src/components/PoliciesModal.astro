---
import PoliciesContent from "./PoliciesContent.astro";
---

<div
  class="policies-modal"
  data-policies
  role="dialog"
  aria-modal="true"
  aria-label="Shop policies"
  hidden
>
  <button
    type="button"
    class="policies-modal__backdrop"
    data-policies-close
    aria-label="Close"
  ></button>
  <div class="policies-modal__panel">
    <div class="policies-modal__head">
      <h2 class="policies-modal__title">SHOP POLICIES</h2>
      <button
        type="button"
        class="policies-modal__close"
        data-policies-close
        aria-label="Close"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
    <div class="policies-modal__body">
      <PoliciesContent />
    </div>
  </div>
</div>

<style is:global>
  .policies-modal[hidden] { display: none; }
  .policies-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    padding: 4vmin;
    animation: policies-modal-in 180ms var(--ease-out-strong);
  }
  .policies-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(6px);
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .policies-modal__panel {
    position: relative;
    z-index: 1;
    width: min(640px, 100%);
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #0f0f0f;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    text-align: left;
  }
  .policies-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .policies-modal__title {
    margin: 0;
    font-family: var(--font-title), system-ui, sans-serif;
    font-size: 1.7rem;
    letter-spacing: calc(0.06em - 2px);
    text-transform: uppercase;
    color: #e8edc6;
  }
  .policies-modal__close {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: transparent;
    color: #f5f5f5;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    cursor: pointer;
    transition: background-color 140ms var(--ease-out-strong),
                color 140ms var(--ease-out-strong);
  }
  .policies-modal__close:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
  }
  .policies-modal__body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 4px 22px 24px;
  }
  .policies-modal__body h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    margin: 1.9rem 0 0.55rem;
  }
  .policies-modal__body section:first-child h2 { margin-top: 1.1rem; }
  .policies-modal__body p,
  .policies-modal__body li {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .policies-modal__body p { margin: 0 0 0.8rem; }
  .policies-modal__body ul { margin: 0 0 0.8rem; padding-left: 1.2rem; }
  .policies-modal__body li { margin-bottom: 0.3rem; }
  .policies-modal__body a { color: var(--color-accent); }
  .policies-modal__body strong { color: #fff; }
  @keyframes policies-modal-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .policies-modal { animation: none; }
    .policies-modal__close { transition: none; }
  }
</style>

<script>
  const modal = document.querySelector<HTMLElement>("[data-policies]");
  if (modal) {
    const body = modal.querySelector<HTMLElement>(".policies-modal__body")!;
    let lastFocus: HTMLElement | null = null;

    const open = (sectionId: string) => {
      lastFocus = document.activeElement as HTMLElement;
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      body.scrollTop = 0;
      if (sectionId) {
        const target = body.querySelector<HTMLElement>(`#${CSS.escape(sectionId)}`);
        if (target) {
          body.scrollTop +=
            target.getBoundingClientRect().top - body.getBoundingClientRect().top;
        }
      }
      modal.querySelector<HTMLButtonElement>(".policies-modal__close")?.focus();
    };
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = "";
      lastFocus?.focus();
    };

    // Intercept the shop's policy links → open the popup at that section.
    document
      .querySelectorAll<HTMLAnchorElement>('a[href^="/policies"]')
      .forEach((a) => {
        a.addEventListener("click", (e) => {
          e.preventDefault();
          open((a.getAttribute("href") || "").split("#")[1] || "");
        });
      });

    modal
      .querySelectorAll<HTMLElement>("[data-policies-close]")
      .forEach((el) => el.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hidden) close();
    });
  }
</script>
