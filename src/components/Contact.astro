---
import { defaultContent } from "../data/defaults";

interface Props {
  contact?: { heading: string; lede: string; email: string; formspreeId: string };
}
const { contact = defaultContent.contact } = Astro.props;
const action = contact.formspreeId
  ? `https://formspree.io/f/${contact.formspreeId}`
  : `mailto:${contact.email}`;
---

<div id="contact-inner">
  <h2 class="section-h2 section-h2--lead">{contact.heading}</h2>
  <p class="contact-lede">{contact.lede}</p>

  <form action={action} method="POST" class="contact-form">
    <div class="contact-form__row">
      <label class="contact-field">
        <span class="contact-field__label">NAME</span>
        <input type="text" name="name" required />
      </label>
      <label class="contact-field">
        <span class="contact-field__label">EMAIL</span>
        <input type="email" name="email" required />
      </label>
    </div>
    <label class="contact-field">
      <span class="contact-field__label">SUBJECT</span>
      <input type="text" name="subject" />
    </label>
    <label class="contact-field">
      <span class="contact-field__label">MESSAGE</span>
      <textarea name="message" rows="5" required></textarea>
    </label>
    <button type="submit" class="contact-send">SEND</button>
  </form>
</div>

<style>
  .contact-lede {
    margin: 0 0 1.5rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.95rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .contact-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .contact-field__label {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 700;
  }
  .contact-field input,
  .contact-field textarea {
    background: #f5f5f5;
    color: #000;
    border: 0;
    border-radius: 4px;
    padding: 0.65rem 0.85rem;
    font-size: 0.95rem;
    font-family: var(--font-sans), system-ui, sans-serif;
  }
  .contact-field textarea {
    resize: vertical;
    min-height: 7rem;
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .contact-send {
    align-self: flex-start;
    background: var(--color-accent-2);
    color: #000;
    border: 0;
    border-radius: 4px;
    padding: 0.55rem 1.25rem;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    cursor: pointer;
    transition: filter 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .contact-send:hover { filter: brightness(1.08); }
  .contact-send:active { transform: scale(0.97); }

  @media (max-width: 899px) {
    .contact-form {
      max-width: 400px;
      margin-inline: auto;
    }
    .contact-form__row { grid-template-columns: 1fr; }
    .contact-send { align-self: center; }
  }
</style>
