---
// The form posts to Formspree by default — replace FORMSPREE_ID with your endpoint
// (https://formspree.io). Until then, the form falls back to a mailto link.
const FORMSPREE_ID = "";
const action = FORMSPREE_ID ? `https://formspree.io/f/${FORMSPREE_ID}` : "mailto:bookings@josefanolin.com";
---

<section class="max-w-4xl mx-auto px-6 py-6 scroll-mt-24">
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide mb-3 text-black">
    BOOK ME!
  </h2>
  <p class="text-black/70 mb-8 text-lg md:text-xl">
    Bookings, press, and general hellos. I read everything.
  </p>

  <form action={action} method="POST" class="grid gap-5">
    <div class="grid md:grid-cols-2 gap-5">
      <label class="grid gap-2">
        <span class="text-sm tracking-widest text-black/70">NAME</span>
        <input
          type="text"
          name="name"
          required
          class="bg-[#f9feab] text-black rounded-md px-4 md:px-5 py-3 md:py-4 text-base md:text-xl focus:outline-none focus:bg-[#fbffc6]"
        />
      </label>
      <label class="grid gap-2">
        <span class="text-sm tracking-widest text-black/70">EMAIL</span>
        <input
          type="email"
          name="email"
          required
          class="bg-[#f9feab] text-black rounded-md px-4 md:px-5 py-3 md:py-4 text-base md:text-xl focus:outline-none focus:bg-[#fbffc6]"
        />
      </label>
    </div>
    <label class="grid gap-2">
      <span class="text-sm tracking-widest text-black/70">SUBJECT</span>
      <input
        type="text"
        name="subject"
        class="bg-[#f9feab] text-black rounded-md px-4 md:px-5 py-3 md:py-4 text-base md:text-xl focus:outline-none focus:bg-[#fbffc6]"
      />
    </label>
    <label class="grid gap-2">
      <span class="text-sm tracking-widest text-black/70">MESSAGE</span>
      <textarea
        name="message"
        rows="4"
        required
        class="bg-[#f9feab] text-black rounded-md px-4 md:px-5 py-3 md:py-4 text-base md:text-xl focus:outline-none focus:bg-[#fbffc6] resize-none"
      ></textarea>
    </label>
    <button
      type="submit"
      class="cursor-pointer justify-self-start text-base font-bold tracking-widest px-9 py-5 bg-black text-[color:var(--color-accent)] rounded-sm hover:bg-neutral-800 active:bg-black transition-colors"
    >
      SEND
    </button>
  </form>
</section>
