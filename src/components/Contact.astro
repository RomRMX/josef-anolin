---
// The form posts to Formspree by default — replace FORMSPREE_ID with your endpoint
// (https://formspree.io). Until then, the form falls back to a mailto link.
const FORMSPREE_ID = "";
const action = FORMSPREE_ID ? `https://formspree.io/f/${FORMSPREE_ID}` : "mailto:bookings@josefanolin.com";
---

<section id="contact" class="max-w-3xl mx-auto px-6 py-6 scroll-mt-24">
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide mb-2">
    BOOK ME!
  </h2>
  <p class="text-neutral-400 mb-5 text-sm">
    Bookings, press, and general hellos. I read everything.
  </p>

  <form action={action} method="POST" class="grid gap-3">
    <div class="grid md:grid-cols-2 gap-3">
      <label class="grid gap-1">
        <span class="text-xs tracking-widest text-neutral-400">NAME</span>
        <input
          type="text"
          name="name"
          required
          class="bg-[color:var(--color-panel)]/50 rounded-md px-3 py-2.5 text-base focus:outline-none focus:bg-[color:var(--color-panel)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]/40"
        />
      </label>
      <label class="grid gap-1">
        <span class="text-xs tracking-widest text-neutral-400">EMAIL</span>
        <input
          type="email"
          name="email"
          required
          class="bg-[color:var(--color-panel)]/50 rounded-md px-3 py-2.5 text-base focus:outline-none focus:bg-[color:var(--color-panel)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]/40"
        />
      </label>
    </div>
    <label class="grid gap-1">
      <span class="text-xs tracking-widest text-neutral-400">SUBJECT</span>
      <input
        type="text"
        name="subject"
        class="bg-[color:var(--color-panel)]/50 rounded-md px-3 py-2.5 text-base focus:outline-none focus:bg-[color:var(--color-panel)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]/40"
      />
    </label>
    <label class="grid gap-1">
      <span class="text-xs tracking-widest text-neutral-400">MESSAGE</span>
      <textarea
        name="message"
        rows="4"
        required
        class="bg-[color:var(--color-panel)]/50 rounded-md px-3 py-2.5 text-base focus:outline-none focus:bg-[color:var(--color-panel)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]/40 resize-none"
      ></textarea>
    </label>
    <button
      type="submit"
      class="cursor-pointer justify-self-start text-xs font-bold tracking-widest px-6 py-3 bg-[color:var(--color-accent)] text-black rounded-sm hover:brightness-110 hover:shadow-[0_8px_24px_rgba(193,252,80,0.4)] active:brightness-95 transition"
    >
      SEND
    </button>
  </form>
</section>
