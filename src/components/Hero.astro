---
---

<section
  class="hero-section relative overflow-hidden"
  aria-label="Josef Anolin — Stand-Up Comedian"
>
  <h1 class="sr-only">
    Josef Anolin — Stand-Up Comedian
  </h1>

  <div class="hero-grid">
    <div class="hero-left">
      <div class="hero-logo-wrap">
        <img
          src="/joe-logo.png"
          alt="Josef Anolin — Stand Up Comedian"
          class="hero-logo select-none pointer-events-none"
        />
        <a href="#contact" class="hero-cta">BOOK ME</a>
      </div>
    </div>

    <div class="hero-right">
      <img
        src="/joe-hero.png"
        alt=""
        aria-hidden="true"
        class="hero-portrait select-none pointer-events-none"
      />
    </div>

    <p class="hero-bio">
      From Oakland, California currently living in Los Angeles, Josef has opened
      for the likes of Tom Segura, Whitney Cummings, and Michael Che. He likes
      telling irreverent stories based on his life and observations.
    </p>
  </div>
</section>

<style>
  .hero-section {
    background: #000;
    height: 100%;
    /* User's spec: 200px from window-top to subject's hat, 250px guard at the
       bottom. Locked at typical desktop heights (1080+); shrinks proportionally
       on shorter viewports. */
    padding-top: clamp(120px, 20dvh, 200px);
    padding-bottom: clamp(160px, 25dvh, 250px);
    padding-left: clamp(1.5rem, 4vw, 5rem);
    padding-right: clamp(1.5rem, 4vw, 5rem);
  }

  .hero-grid {
    height: 100%;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    grid-template-rows: 1fr;
    column-gap: clamp(1.5rem, 4vw, 60px);
    align-items: start;
    /* Bio is positioned absolutely below — grid only handles columns. */
  }

  /* LEFT column — title stack + BOOK ME tight beneath */
  .hero-left {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    /* Anchor logo+button to TOP so the title's top sits at row top
       (= section padding-top = 200px from window). No flex centering
       within the column — that creates the floating-row look. */
    justify-content: flex-start;
    align-items: flex-start;
    min-width: 0;
    align-self: start;
  }
  /* logo-wrap also containers the CTA so the CTA centers under the
     logo's width, not the column's width. */
  .hero-logo-wrap {
    width: 100%;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  /* RIGHT column — portrait scaled to fit, hat top at row top (= 200px from window). */
  .hero-right {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    /* Anchor to TOP so portrait hat aligns with logo top at y=200. */
    align-items: flex-start;
    justify-content: center;
    min-height: 0;
    min-width: 0;
    align-self: start;
    height: 100%;
  }
  .hero-portrait {
    /* Cap height by viewport so portrait never overflows the row track.
       Reserve top pad (200) + bottom pad (250) + bio area (~140). */
    max-height: calc(100dvh - 200px - 250px - 140px);
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* CTA — sits inside .hero-logo-wrap so its center matches the logo's center. */
  .hero-cta {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: #000;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 1rem;
    letter-spacing: 0.16em;
    padding: 0.85rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 0.18s ease, transform 0.18s ease;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hero-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
  }

  /* BIO — magazine pull-quote, anchored to the bottom of the safe zone
     so its lowest pixel sits exactly 250px from the viewport bottom. */
  .hero-bio {
    position: absolute;
    left: clamp(1.5rem, 4vw, 5rem);
    bottom: clamp(160px, 25dvh, 250px);
    margin: 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    border-left: 3px solid var(--color-accent);
    font-family: var(--font-body), system-ui, sans-serif;
    font-style: italic;
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1.55;
    color: rgb(229 229 229);
    max-width: 78ch;
  }

  /* Mobile: ditch the grid, use a simple flex column. Order:
     logo + button → portrait → bio. Bio stays in flow (no abs pos). */
  @media (max-width: 767px) {
    .hero-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
      height: auto;
      min-height: 100%;
    }
    .hero-left {
      width: 100%;
      align-items: center;
    }
    .hero-logo-wrap { max-width: 92%; margin: 0 auto; }
    .hero-right {
      width: 100%;
      height: auto;
      justify-content: center;
    }
    .hero-portrait {
      max-width: 65%;
      max-height: none;
    }
    .hero-bio {
      position: static;
      max-width: 100%;
      margin: 0;
      padding-left: 1rem;
    }
  }
</style>
