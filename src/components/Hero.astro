---
import { statSync } from "node:fs";
import { fileURLToPath } from "node:url";
import SocialIcon from "./SocialIcon.astro";

const subjectImagePath = fileURLToPath(
  new URL("../../public/subject_image.png", import.meta.url),
);
const subjectImageSrc = `/subject_image.png?v=${statSync(subjectImagePath).mtimeMs | 0}`;

const navLinks = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "HIT ME UP" },
];

const socials = [
  { label: "YouTube",   href: "https://www.youtube.com/@comedianjoe510",                                  icon: "youtube"   as const },
  { label: "Instagram", href: "https://www.instagram.com/comedianjoe510/",                                icon: "instagram" as const },
  { label: "TikTok",    href: "https://www.tiktok.com/@comedianjoe510?is_from_webapp=1&sender_device=pc", icon: "tiktok"    as const },
  { label: "Facebook",  href: "https://www.facebook.com/JosefAnolinComedian",                             icon: "facebook"  as const },
  { label: "Threads",   href: "https://www.threads.com/@comedianjoe510",                                  icon: "threads"   as const },
  { label: "Email",     href: "mailto:josefanolin@gmail.com",                                             icon: "email"     as const },
];
---

<section
  class="hero-section"
  aria-label="Josef Anolin — Stand-Up Comedian"
>
  <h1 class="sr-only">Josef Anolin — Stand-Up Comedian</h1>

  <div class="hero-stage">
    <a href="#contact" class="hero-tag" aria-label="Book Josef">BOOK ME!</a>
    <img
      src={subjectImageSrc}
      alt="Josef Anolin"
      class="hero-portrait select-none pointer-events-none"
    />
    <nav class="hero-nav" aria-label="Primary">
      {navLinks.map((l) => (
        <a href={l.href} data-target={l.href} class="hero-nav-link">
          {l.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="hero-bio">
    <p class="hero-bio__p">
      Josef Anolin is an LA-based stand-up comedian and actor whose mischievous,
      anecdotal humor has made him a standout on the Southern California circuit.
      He's been featured at Punch Line SF, Cobb's Comedy Club, and Netflix Is A
      Joke Fest 2026, and performs regularly at the Hollywood Improv Lab. Off
      stage, he's on his Android — mostly to annoy you with green text bubbles.
    </p>
    <p class="hero-bio__p">
      Follow him at @comedianjoe510 and josefanolin.com for dates and upcoming
      projects.
    </p>
  </div>

  <ul class="hero-socials" aria-label="Social links">
    {socials.map((s) => (
      <li>
        <a
          href={s.href}
          target={s.href.startsWith("http") ? "_blank" : undefined}
          rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
          aria-label={s.label}
          title={s.label}
          class="hero-socials__link"
        >
          <SocialIcon name={s.icon} class="hero-socials__icon" />
        </a>
      </li>
    ))}
  </ul>

</section>

<style>
  /* All sizing/spacing/layout values come from CSS custom properties defined
     in src/styles/global.css. Per-breakpoint defaults cascade through :root
     media queries there. */

  .hero-section {
    position: relative;
    height: 100%;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--hero-section-pt) var(--hero-section-px) var(--hero-section-pb);
    min-height: var(--hero-section-min-height);
    text-align: center;
    transform: translateX(var(--hero-section-x-shift));
  }

  .hero-stage {
    position: relative;
    width: 100%;
    max-width: var(--hero-stage-max-width);
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    flex-shrink: 0;
  }
  .hero-portrait {
    position: absolute;
    top: var(--hero-subject-offset-y);
    left: 50%;
    transform: translateX(calc(-50% + var(--hero-subject-offset-x, 0px))) scale(var(--hero-subject-scale));
    transform-origin: top center;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 1;
  }
  .hero-tag {
    position: absolute;
    top: var(--hero-tag-top);
    left: var(--hero-tag-left);
    z-index: 3;
    background: var(--color-accent);
    color: #000;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: var(--hero-tag-font-size);
    letter-spacing: 0.14em;
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transform: rotate(var(--hero-tag-rotate));
    transition: filter 180ms var(--ease-out-strong),
                transform 180ms var(--ease-out-strong);
  }
  /* Quick, fierce rattle when you hover BOOK ME. */
  @keyframes book-rattle {
    0%   { transform: rotate(var(--hero-tag-rotate)) translateX(0); }
    12%  { transform: rotate(calc(var(--hero-tag-rotate) - 6deg)) translateX(-3px); }
    25%  { transform: rotate(calc(var(--hero-tag-rotate) + 6deg)) translateX(3px); }
    38%  { transform: rotate(calc(var(--hero-tag-rotate) - 5deg)) translateX(-3px); }
    50%  { transform: rotate(calc(var(--hero-tag-rotate) + 5deg)) translateX(2px); }
    63%  { transform: rotate(calc(var(--hero-tag-rotate) - 4deg)) translateX(-2px); }
    78%  { transform: rotate(calc(var(--hero-tag-rotate) + 3deg)) translateX(1px); }
    100% { transform: rotate(var(--hero-tag-rotate)) translateX(0); }
  }
  @media (hover: hover) and (pointer: fine) {
    .hero-tag:hover {
      filter: brightness(1.08);
      animation: book-rattle 0.35s var(--ease-out-strong);
    }
  }
  .hero-tag:active { transform: rotate(var(--hero-tag-rotate)) scale(0.96); }
  @media (prefers-reduced-motion: reduce) {
    .hero-tag:hover { animation: none; }
  }

  .hero-bio {
    margin: calc(clamp(1.25rem, 3dvh, 2rem) + var(--hero-bio-extra-top)) auto 0;
    max-width: var(--hero-bio-max-width);
    font-size: var(--hero-bio-font-size);
    line-height: var(--hero-bio-line-height);
    color: rgb(210 210 210);
    flex-shrink: 0;
  }
  .hero-bio__p { margin: 0; }
  .hero-bio__p + .hero-bio__p { margin-top: 0.85rem; }

  .hero-socials {
    display: var(--hero-socials-display);
    list-style: none;
    margin: var(--hero-socials-margin-top) 0 0;
    padding: 0;
    align-items: center;
    justify-content: center;
    gap: var(--hero-socials-gap);
    flex-shrink: 0;
  }
  .hero-socials__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--hero-socials-icon) + 10px);
    height: calc(var(--hero-socials-icon) + 10px);
    border-radius: 4px;
    color: var(--socials-color);
    transition: background-color 160ms var(--ease-out-strong),
                color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  .hero-socials__link:hover {
    color: var(--socials-hover-color);
  }
  .hero-socials__link:hover {
    background-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }
  .hero-socials__link:active { transform: scale(0.94); }
  .hero-socials__icon {
    width: var(--hero-socials-icon);
    height: var(--hero-socials-icon);
    user-select: none;
    pointer-events: none;
  }

  .hero-nav {
    position: absolute;
    display: var(--hero-nav-display);
    top: var(--hero-nav-top);
    right: var(--hero-nav-right);
    z-index: 4;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--hero-nav-gap);
  }
  .hero-nav-link {
    position: relative;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: var(--hero-nav-font-size);
    letter-spacing: 0.08em;
    color: #fff;
    text-decoration: none;
    transition: color 160ms var(--ease-out-strong);
  }
  .hero-nav-link:hover,
  .hero-nav-link.is-active {
    color: var(--color-accent);
  }
  .hero-nav-link.is-active::after {
    content: " —";
    position: absolute;
    left: 100%;
    top: 0;
    margin-left: 0.35em;
    color: var(--color-accent);
  }
</style>

<script>
  // Highlight the nav link whose section is currently in the viewport.
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".hero-nav-link[data-target]"),
  );
  const targets = links
    .map((a) => {
      const sel = a.dataset.target;
      return sel ? document.querySelector(sel) : null;
    })
    .filter(Boolean) as Element[];

  if (links.length && targets.length && "IntersectionObserver" in window) {
    const setActive = (id: string | null) => {
      for (const a of links) {
        a.classList.toggle("is-active", a.dataset.target === `#${id}`);
      }
    };
    const io = new IntersectionObserver(
      (entries) => {
        // Pick the entry closest to the top that is intersecting.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: "-30% 0px -55% 0px", threshold: 0 },
    );
    targets.forEach((t) => io.observe(t));
  }
</script>
