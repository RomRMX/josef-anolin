---
---

<section class="relative h-full overflow-hidden">
  {/* Background — halftone grunge, covers ~72% from top. Below is a solid
      dark band that hosts the bio paragraph. */}
  <div
    class="absolute inset-x-0 top-0 h-[72%] bg-cover bg-center"
    style="background-image: url('/joe-bg.webp');"
  >
  </div>
  <div class="absolute inset-x-0 top-[72%] bottom-0 bg-[color:var(--color-bg)]"></div>

  {/* Layout: visual area on top, bio band on bottom. The portrait is
      positioned absolutely so it bleeds across the divide. */}
  <div class="relative h-full flex flex-col">
    {/* Visual area */}
    <div class="flex-1 relative">
      <div
        class="relative h-full max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 items-center gap-6 pt-20 md:pt-24"
      >
        <div class="flex flex-col items-start gap-6 z-10">
          <img
            src="/joe-logo.png"
            alt="Josef Anolin — Stand-Up Comedian"
            class="w-full max-w-md drop-shadow-[0_8px_30px_rgba(0,0,0,0.5)]"
          />
          <a
            href="#contact"
            class="inline-block px-10 py-3.5 bg-[color:var(--color-accent)] text-black font-extrabold tracking-widest text-base rounded-full shadow-[0_8px_24px_rgba(245,233,11,0.25)] hover:scale-[1.04] active:scale-[0.97] transition-transform"
          >
            BOOK ME!
          </a>
        </div>
        {/* right column intentionally empty — portrait is absolute below */}
        <div></div>
      </div>
    </div>

    {/* Bio band */}
    <div class="relative z-10 px-6 pb-10 pt-6 md:pb-14 md:pt-8 text-center">
      <p
        class="max-w-3xl mx-auto text-neutral-200 leading-loose text-sm md:text-base"
      >
        From Oakland, California currently living in Los Angeles, Josef has
        opened for the likes of Tom Segura, Whitney Cummings, and Michael Che.
        He likes telling irreverent stories based on his life and observations.
        He has an Android phone because he likes pissing you off with his green
        text bubbles.
      </p>
    </div>
  </div>

  {/* Portrait — flush right, bleeds across the visual/bio divide */}
  <img
    src="/joe-hero.png"
    alt="Portrait of Josef Anolin"
    class="hero-portrait pointer-events-none select-none absolute right-0 md:right-[2%] lg:right-[4%] bottom-[16%] md:bottom-[12%] h-[70%] md:h-[80%] w-auto object-contain object-bottom z-[5]"
  />
</section>
