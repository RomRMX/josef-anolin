---
---

<section
  class="hero-section relative overflow-hidden"
  aria-label="Josef Anolin — Stand-Up Comedian"
>
  <h1 class="sr-only">
    Josef Anolin — Stand-Up Comedian
  </h1>

  <div class="hero-comp">
    <img
      src="/joe-hero.png"
      alt=""
      aria-hidden="true"
      class="hero-portrait select-none pointer-events-none"
    />
    <div class="hero-logo-wrap">
      <img
        src="/joe-logo.png"
        alt="Josef Anolin — Stand Up Comedian"
        class="hero-logo select-none pointer-events-none"
      />
      <a href="#contact" class="hero-cta">BOOK ME</a>
    </div>
  </div>

  <p class="hero-bio">
    From Oakland, California currently living in Los Angeles, Josef has opened
    for the likes of Tom Segura, Whitney Cummings, and Michael Che. He likes
    telling irreverent stories based on his life and observations.
  </p>
</section>

<style>
  .hero-section {
    background: #000;
    height: 100%;
    /* 200px from window-top to subject's hat / 250px guard at bottom.
       Locked at 1080+ viewports; shrinks proportionally on shorter ones. */
    padding-top: clamp(120px, 20dvh, 200px);
    padding-bottom: clamp(160px, 25dvh, 250px);
    padding-left: clamp(1.5rem, 4vw, 5rem);
    padding-right: clamp(1.5rem, 4vw, 5rem);
    display: flex;
    flex-direction: column;
  }

  /* COMP — portrait + logo overlap in the same grid cell. Sized
     primarily by WIDTH so vertical resizes don't shrink them
     drastically. Both images carry a soft dvh-based max-height that
     activates only on short viewports (≲ 1080) so bio + 40px gap
     still fits inside the 250 bottom guard. */
  .hero-comp {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    flex-shrink: 0;
  }

  /* Portrait — anchored right, width-only sizing (no dvh-based cap)
     so vertical resizes don't shrink it. Behavior matches the logo. */
  .hero-portrait {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
    align-self: start;
    width: 42%;
    max-width: 540px;
    height: auto;
    display: block;
    z-index: 1;
  }

  /* Logo + button — shifted toward center so logo OVERLAPS portrait's
     left edge by ~7%. */
  .hero-logo-wrap {
    grid-column: 1;
    grid-row: 1;
    justify-self: start;
    align-self: start;
    margin-left: 5%;
    width: 60%;
    max-width: 660px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  /* CTA — sits inside .hero-logo-wrap so its center matches the logo's center. */
  .hero-cta {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: #000;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 1rem;
    letter-spacing: 0.16em;
    padding: 0.85rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 0.18s ease, transform 0.18s ease;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hero-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
  }

  /* BIO — pinned to bottom of section flex container.
     margin-top: auto pushes bio to bottom (= section's padding-bottom guard).
     padding-top: 40px enforces a minimum 40px gap above the bio so it never
     crashes into BOOK ME on shorter/narrower viewports. */
  .hero-bio {
    margin: 0;
    margin-top: auto;
    padding: 40px 0 0 1.25rem;
    border-left: 3px solid var(--color-accent);
    border-image: none;
    /* The vertical accent rule should only span the text height, not the
       40px top padding. Use a wrapping pseudo-element trick: */
    background-clip: padding-box;
    font-family: var(--font-body), system-ui, sans-serif;
    font-style: italic;
    font-size: clamp(0.85rem, 1.05vw, 1rem);
    line-height: 1.55;
    color: rgb(229 229 229);
    max-width: 78ch;
    flex-shrink: 0;
    align-self: flex-start;
    /* Use box-shadow inset for the accent rule so it can sit below the
       40px top gap. Padding-left + box-shadow drawn from bottom up. */
  }
  /* Trim the accent rule so it doesn't draw across the 40px top gap. */
  .hero-bio {
    border-left: 0;
    position: relative;
    padding-left: calc(1.25rem + 3px);
  }
  .hero-bio::before {
    content: "";
    position: absolute;
    left: 0;
    top: 40px;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
  }

  /* MOBILE — portrait on top, then logo+button, then bio. */
  @media (max-width: 767px) {
    .hero-comp {
      grid-template-rows: auto auto;
      row-gap: 1rem;
    }
    .hero-portrait {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      align-self: center;
      width: 60%;
      max-width: 280px;
      margin: 0 auto;
    }
    .hero-logo-wrap {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      margin-left: 0;
      width: 92%;
      max-width: 480px;
    }
    .hero-bio {
      max-width: 100%;
      font-size: 0.85rem;
    }
  }
</style>
