---
const navLinks = [
  { href: "#shows", label: "SHOWS" },
  { href: "#media", label: "MEDIA" },
  { href: "#shop", label: "SHOP" },
  { href: "#contact", label: "HIT ME UP" },
];
---

<section
  class="hero-section"
  aria-label="Josef Anolin — Stand-Up Comedian"
>
  <h1 class="sr-only">Josef Anolin — Stand-Up Comedian</h1>

  <div class="hero-stage">
    <a href="#contact" class="hero-tag" aria-label="Book Josef">BOOK ME!</a>
    <img
      src="/joe-hero.png"
      alt=""
      aria-hidden="true"
      class="hero-portrait select-none pointer-events-none"
    />
    <img
      src="/joe-logo.png"
      alt="Josef Anolin — Stand Up Comedian"
      class="hero-logo select-none pointer-events-none"
    />
  </div>

  <p class="hero-bio">
    From Oakland, California currently living in Los Angeles, Josef has opened
    for the likes of Tom Segura, Whitney Cummings, and Michael Che. He likes
    telling irreverent stories based on his life and observations. He has an
    Android phone because he likes pissing you off with his green text bubbles.
  </p>

  <nav class="hero-nav" aria-label="Primary">
    {navLinks.map((l) => (
      <a href={l.href} data-target={l.href} class="hero-nav-link">
        {l.label}
      </a>
    ))}
  </nav>
</section>

<style>
  .hero-section {
    height: 100%;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: clamp(2rem, 5dvh, 4rem) clamp(1.25rem, 3vw, 3rem) 2rem;
    text-align: center;
    overflow: hidden;
    transform: translateX(100px);
  }

  /* Stage = portrait + logo overlap (inherits the original treatment but
     scaled to fit the narrower column). The BOOK ME tag sits absolutely
     over the brushstroke so it can rotate into the corner. */
  .hero-stage {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    flex-shrink: 0;
  }
  .hero-portrait {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 1;
  }
  .hero-logo {
    position: absolute;
    left: 50%;
    bottom: -2%;
    transform: translateX(-50%);
    width: 96%;
    height: auto;
    z-index: 2;
  }
  .hero-tag {
    position: absolute;
    top: 8%;
    left: 4%;
    z-index: 3;
    background: var(--color-accent);
    color: #000;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: clamp(0.75rem, 0.9vw, 0.95rem);
    letter-spacing: 0.14em;
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transform: rotate(-6deg);
    transition: filter 180ms var(--ease-out-strong),
                transform 180ms var(--ease-out-strong);
  }
  @media (hover: hover) and (pointer: fine) {
    .hero-tag:hover {
      filter: brightness(1.08);
      transform: rotate(-6deg) translateY(-2px);
    }
  }
  .hero-tag:active { transform: rotate(-6deg) scale(0.96); }

  .hero-bio {
    margin: clamp(1.25rem, 3dvh, 2rem) auto 0;
    max-width: 38ch;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
    line-height: 1.55;
    color: rgb(210 210 210);
    flex-shrink: 0;
  }

  .hero-nav {
    margin-top: clamp(1.25rem, 3dvh, 2rem);
    background: #3a4214;
    border-radius: 999px;
    padding: 0.65rem 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.75rem);
    flex-shrink: 0;
  }
  .hero-nav-link {
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: clamp(0.85rem, 0.8rem + 0.2vw, 1rem);
    letter-spacing: 0.12em;
    color: #fff;
    text-decoration: none;
    transition: color 160ms var(--ease-out-strong);
  }
  .hero-nav-link:hover,
  .hero-nav-link.is-active {
    color: var(--color-accent-2);
  }

  /* Mobile — looser padding, smaller stage. The hero nav pill is hidden
     because the fixed mobile header (Header.astro) already exposes the
     same links and is always visible. */
  @media (max-width: 767px) {
    .hero-section {
      padding-top: 5rem;
      padding-bottom: 3rem;
      min-height: 100dvh;
      transform: none;
    }
    .hero-stage {
      max-width: 360px;
    }
    .hero-bio { font-size: 0.875rem; line-height: 1.45; max-width: 32ch; }
    .hero-nav { display: none; }
  }
</style>

<script>
  // Highlight the nav link whose section is currently in the viewport.
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".hero-nav-link[data-target]"),
  );
  const targets = links
    .map((a) => {
      const sel = a.dataset.target;
      return sel ? document.querySelector(sel) : null;
    })
    .filter(Boolean) as Element[];

  if (links.length && targets.length && "IntersectionObserver" in window) {
    const setActive = (id: string | null) => {
      for (const a of links) {
        a.classList.toggle("is-active", a.dataset.target === `#${id}`);
      }
    };
    const io = new IntersectionObserver(
      (entries) => {
        // Pick the entry closest to the top that is intersecting.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: "-30% 0px -55% 0px", threshold: 0 },
    );
    targets.forEach((t) => io.observe(t));
  }
</script>
