---
const dates = [
  {
    date: "08/28/25",
    city: "Oakland",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "San Francisco",
    venue: "Fisherman's Wharf",
    address: "1992 Boulevard Blvd.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "Santa Rosa",
    venue: "Rudy Rucker",
    address: "1982 Avenue Ave.",
    tickets: "https://www.ticketmaster.com",
  },
];
---

<section id="dates" class="max-w-6xl mx-auto px-6 py-6 scroll-mt-24 grid grid-cols-1 md:grid-cols-[minmax(280px,1fr)_3fr] gap-4 md:gap-12 items-start">
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide md:text-right text-black">
    DATES
  </h2>
  <ul class="border-t border-black/15">
    {
      dates.map((d) => (
        <li class="grid grid-cols-1 md:grid-cols-[140px_1fr_auto] md:items-center gap-3 md:gap-8 py-5 border-b border-black/15">
          <div class="text-black text-base md:text-xl tracking-wider">
            {d.date}
          </div>
          <div class="leading-tight min-w-0">
            <div class="font-bold text-xl md:text-2xl text-black">{d.city}</div>
            <div class="text-base md:text-lg text-black/80">{d.venue}</div>
            <div class="text-sm md:text-base text-black/75">{d.address}</div>
          </div>
          <a
            href={d.tickets}
            target="_blank"
            rel="noopener noreferrer"
            class="justify-self-start md:justify-self-end md:-translate-x-[210px] inline-flex items-center justify-center min-h-11 text-sm font-bold tracking-widest px-5 py-3 bg-black text-[color:var(--color-accent)] rounded-sm hover:bg-neutral-800 active:bg-black transition-colors"
          >
            TICKETS
          </a>
        </li>
      ))
    }
  </ul>
</section>
