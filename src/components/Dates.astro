---
const dates = [
  {
    date: "08/28/25",
    city: "Oakland",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "San Francisco",
    venue: "Fisherman's Wharf",
    address: "1992 Boulevard Blvd.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "Santa Rosa",
    venue: "Rudy Rucker",
    address: "1982 Avenue Ave.",
    tickets: "https://www.ticketmaster.com",
  },
];
---

<section id="dates" data-stagger class="max-w-6xl mx-auto px-6 py-6 scroll-mt-24 grid grid-cols-1 md:grid-cols-[minmax(280px,1fr)_3fr] gap-4 md:gap-12 items-start">
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl tracking-wide md:text-right text-black">
    DATES
  </h2>
  <ul class="dates-list border-t border-black/15">
    {
      dates.map((d) => (
        <li class="date-row grid grid-cols-1 md:grid-cols-[140px_1fr_auto] md:items-center gap-3 md:gap-8 py-5 border-b border-black/15">
          <div class="text-black text-base md:text-xl tracking-wider">
            {d.date}
          </div>
          <div class="leading-tight min-w-0">
            <div class="font-bold text-xl md:text-2xl text-black">{d.city}</div>
            <div class="text-base md:text-lg text-black/80">{d.venue}</div>
            <div class="text-sm md:text-base text-black/75">{d.address}</div>
          </div>
          <a
            href={d.tickets}
            target="_blank"
            rel="noopener noreferrer"
            class="tickets-cta justify-self-start md:justify-self-end md:-translate-x-[210px] inline-flex items-center justify-center min-h-11 text-sm font-bold tracking-widest px-5 py-3 bg-black text-[color:var(--color-accent)] rounded-sm"
          >
            TICKETS
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* Stagger entry — rows fade up when the shows card scrolls into view.
     `is-visible` is added by the IO in index.astro. */
  .date-row {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 360ms var(--ease-out-strong),
                transform 360ms var(--ease-out-strong);
  }
  .dates-list.is-visible .date-row {
    opacity: 1;
    transform: translateY(0);
  }
  .dates-list.is-visible .date-row:nth-child(1) { transition-delay: 60ms; }
  .dates-list.is-visible .date-row:nth-child(2) { transition-delay: 120ms; }
  .dates-list.is-visible .date-row:nth-child(3) { transition-delay: 180ms; }
  .dates-list.is-visible .date-row:nth-child(4) { transition-delay: 240ms; }

  /* TICKETS press + hover. translate-x is preserved via the second value. */
  .tickets-cta {
    transition: background-color 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  @media (hover: hover) and (pointer: fine) {
    .tickets-cta:hover { background-color: rgb(38 38 38); }
  }
  @media (min-width: 768px) {
    .tickets-cta:active {
      transform: translateX(-210px) scale(0.97);
    }
  }
  @media (max-width: 767px) {
    .tickets-cta:active { transform: scale(0.97); }
  }

  @media (prefers-reduced-motion: reduce) {
    .date-row {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .tickets-cta { transition: background-color 160ms ease; }
    .tickets-cta:active { transform: none; }
  }
</style>
