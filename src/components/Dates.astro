---
const dates = [
  {
    date: "08/28/25",
    city: "Oakland, CA",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "Oakland, CA",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "Oakland, CA",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
  {
    date: "08/28/25",
    city: "Oakland, CA",
    venue: "Luka's Lounge",
    address: "1984 Somewhere Ave.",
    tickets: "https://www.ticketmaster.com",
  },
];
---

<div id="dates" data-stagger>
  <h2 class="section-h2 section-h2--lead">SHOWS</h2>
  <ul class="dates-list">
    {dates.map((d) => (
      <li class="date-row">
        <div class="date-row__date">{d.date}</div>
        <div class="date-row__city">{d.city.toUpperCase()}</div>
        <div class="date-row__venue">
          <span class="date-row__venue-name">{d.venue.toUpperCase()}</span>
          <span class="date-row__venue-addr">{d.address}</span>
        </div>
        <a
          href={d.tickets}
          target="_blank"
          rel="noopener noreferrer"
          class="date-row__cta"
        >
          BUY TIX
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .dates-list {
    list-style: none;
    margin: 0;
    /* Right padding leaves room for the 160px BUY TIX shift without
       letting the venue/address text run into the button. */
    padding: 0 160px 0 0;
  }
  .date-row {
    display: grid;
    grid-template-columns: 80px 110px 1fr auto;
    align-items: center;
    column-gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--color-ink);
    font-size: 0.85rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 360ms var(--ease-out-strong),
                transform 360ms var(--ease-out-strong);
  }
  .dates-list.is-visible .date-row {
    opacity: 1;
    transform: translateY(0);
  }
  .dates-list.is-visible .date-row:nth-child(1) { transition-delay: 60ms; }
  .dates-list.is-visible .date-row:nth-child(2) { transition-delay: 120ms; }
  .dates-list.is-visible .date-row:nth-child(3) { transition-delay: 180ms; }
  .dates-list.is-visible .date-row:nth-child(4) { transition-delay: 240ms; }

  .date-row__date,
  .date-row__city,
  .date-row__venue-name {
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .date-row__venue {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    min-width: 0;
  }
  .date-row__venue-addr {
    color: rgba(255, 255, 255, 0.7);
    font-weight: 400;
  }
  .date-row__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-2);
    color: #000;
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    text-decoration: none;
    transition: filter 160ms var(--ease-out-strong),
                transform 140ms var(--ease-out-strong);
  }
  @media (hover: hover) and (pointer: fine) {
    .date-row__cta:hover { filter: brightness(1.08); }
  }
  .date-row__cta:active { transform: scale(0.96); }

  @media (max-width: 767px) {
    .dates-list { padding-right: 0; }
    .date-row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "date cta"
        "city cta"
        "venue venue";
      column-gap: 0.75rem;
      row-gap: 0.2rem;
    }
    .date-row__date { grid-area: date; }
    .date-row__city { grid-area: city; font-size: 1rem; }
    .date-row__venue { grid-area: venue; font-size: 0.8rem; }
    .date-row__cta { grid-area: cta; align-self: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .date-row { opacity: 1; transform: none; transition: none; }
    .date-row__cta:active { transform: none; }
  }
</style>
