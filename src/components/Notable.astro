---
const groups = [
  {
    label: "Headlining",
    items: ["Laughs Unlimited (Sacramento, CA)"],
  },
  {
    label: "Featured",
    items: [
      "Punch Line (San Francisco)",
      "Punch Line (Sacramento)",
      "Cobb's Comedy Club (San Francisco)",
      "The San Jose Improv",
      "Rooster T. Feathers",
    ],
  },
  {
    label: "Festivals",
    items: [
      "Netflix is a Joke Fest 2026",
      "Clusterfest Bay Area Showcase 2018",
      "Sketchfest (2015, 2017, 2018, 2023)",
      "Outside Lands 2016",
      "North Carolina Comedy Festival 2018",
    ],
  },
];
---

<div id="notable">
  <h2 class="section-h2 section-h2--sub">APPEARANCES</h2>
  <div class="notable-list">
    {groups.map((g) => (
      <section class="notable-group">
        <h3 class="notable-group__label">{g.label.toUpperCase()}</h3>
        <ul class="notable-group__items">
          {g.items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    ))}
  </div>
</div>

<style>
  /* Extra gap so APPEARANCES sits well clear of the SHOWS block above. */
  #notable .section-h2--sub {
    margin-top: 7rem;
  }
  /* Single column — HEADLINING, FEATURED, then FESTIVALS stacked. */
  .notable-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .notable-group {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 360ms var(--ease-out-strong),
                transform 360ms var(--ease-out-strong);
  }
  .notable-list.is-visible .notable-group { opacity: 1; transform: translateY(0); }
  .notable-list.is-visible .notable-group:nth-child(1) { transition-delay: 80ms; }
  .notable-list.is-visible .notable-group:nth-child(2) { transition-delay: 140ms; }
  .notable-list.is-visible .notable-group:nth-child(3) { transition-delay: 200ms; }

  .notable-group__label {
    font-weight: 800;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: var(--color-accent);
    margin: 0 0 0.4rem;
  }
  .notable-group__items {
    list-style: none;
    margin: 0;
    padding: 0;
    color: #ffffff;
    font-size: 18px;
    line-height: 1.5;
  }

  @media (max-width: 899px) {
    .notable-list { gap: 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .notable-group { opacity: 1; transform: none; transition: none; }
  }
</style>
