---
const groups = [
  {
    label: "Headlining",
    items: ["Laughs Unlimited (Sacramento, CA)"],
  },
  {
    label: "Featured",
    items: [
      "Punch Line (San Francisco)",
      "Punch Line (Sacramento)",
      "Cobb's Comedy Club (San Francisco)",
      "The San Jose Improv",
      "Rooster T. Feathers",
    ],
  },
  {
    label: "Festivals",
    items: [
      "Clusterfest Bay Area Showcase 2018",
      "Sketchfest (2015, 2017, 2018, 2023)",
      "Outside Lands 2016",
      "North Carolina Comedy Festival 2018",
    ],
  },
];
---

<div id="notable">
  <h2 class="section-h2 section-h2--sub">APPEARANCES</h2>
  <div class="notable-list">
    <div class="notable-col">
      {groups.slice(0, 2).map((g) => (
        <section class="notable-group">
          <h3 class="notable-group__label">{g.label.toUpperCase()}</h3>
          <ul class="notable-group__items">
            {g.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))}
    </div>
    <div class="notable-col">
      <section class="notable-group">
        <h3 class="notable-group__label">{groups[2].label.toUpperCase()}</h3>
        <ul class="notable-group__items">
          {groups[2].items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </div>
  </div>
</div>

<style>
  .notable-list {
    display: grid;
    /* Each column sizes to its widest item so the FESTIVALS shift can
       sit cleanly in the gap without colliding with FEATURED text. */
    grid-template-columns: max-content max-content;
    gap: 1.75rem 4.5rem;
  }
  @media (min-width: 768px) {
    /* FESTIVALS column shifted left toward the FEATURED list. */
    .notable-list .notable-col:nth-child(2) {
      transform: translateX(-40px);
    }
  }
  .notable-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .notable-group {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 360ms var(--ease-out-strong),
                transform 360ms var(--ease-out-strong);
  }
  .notable-list.is-visible .notable-group { opacity: 1; transform: translateY(0); }
  .notable-list.is-visible .notable-col:nth-child(1) .notable-group:nth-child(1) { transition-delay: 80ms; }
  .notable-list.is-visible .notable-col:nth-child(1) .notable-group:nth-child(2) { transition-delay: 140ms; }
  .notable-list.is-visible .notable-col:nth-child(2) .notable-group:nth-child(1) { transition-delay: 200ms; }

  .notable-group__label {
    font-weight: 800;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: var(--color-accent);
    margin: 0 0 0.4rem;
  }
  .notable-group__items {
    list-style: none;
    margin: 0;
    padding: 0;
    color: #ffffff;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 767px) {
    .notable-list { grid-template-columns: 1fr; gap: 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .notable-group { opacity: 1; transform: none; transition: none; }
  }
</style>
