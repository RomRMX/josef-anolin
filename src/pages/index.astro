---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Dates from "../components/Dates.astro";
import Notable from "../components/Notable.astro";
import Videos from "../components/Videos.astro";
import Pics from "../components/Pics.astro";
import Shop from "../components/Shop.astro";
import Contact from "../components/Contact.astro";
---

<Base>
  <main class="layout">
    <aside class="hero-rail">
      <Hero />
    </aside>

    <div class="content-rail">
      <section id="shows" class="rail-section">
        <Dates />
        <Notable />
      </section>

      <section id="media" class="rail-section">
        <Videos />
        <Pics />
      </section>

      <section id="shop" class="rail-section">
        <Shop />
      </section>

      <section id="contact" class="rail-section rail-section--contact">
        <Contact />
      </section>
    </div>
  </main>
</Base>

<style is:global>
  /* Two-column desktop: sticky hero on the left, scrolling content on the
     right. Mobile collapses to a single column with the hero in normal flow. */
  .layout {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-bg);
  }
  .hero-rail {
    display: block;
  }
  .content-rail {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .rail-section {
    padding: 4rem 1.25rem;
    scroll-margin-top: 1rem;
  }
  .rail-section + .rail-section {
    padding-top: 2rem;
  }

  /* Two-column layout only kicks in at >= 1024px so the bio and the
     -50px-shifted content rail can never collide at narrow widths. */
  @media (min-width: 1024px) {
    .layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
    .hero-rail {
      position: sticky;
      top: 0;
      height: 100dvh;
      overflow: hidden;
    }
    .content-rail {
      min-width: 0;
    }
    /* Even vertical spread + asymmetric padding: less padding on the left
       so content visually sits closer to the column gutter (the previous
       intent of the -50px transform) without ever crossing into col1. */
    .rail-section {
      padding: 5rem 2.5rem 5rem 0;
      min-height: 100dvh;
    }
    /* Contact section keeps the standard top padding; HIT ME UP gets
       pushed 160px down via margin on its inner wrapper, and the
       section keeps an extra 200px breathing room at the bottom. */
    .rail-section--contact {
      padding-bottom: calc(5rem + 200px);
    }
    .rail-section--contact #contact-inner {
      margin-top: 160px;
    }
    /* Cap col2 content at 600px wide — the section-h2's stay full-rail
       width so their hairlines can still bleed to the viewport edge. */
    .dates-list,
    #notable .notable-list,
    .videos-grid,
    .pics-grid,
    .tee-list,
    .contact-lede,
    .contact-form {
      max-width: 600px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rail {
      position: relative;
      height: auto;
    }
  }
</style>

<script>
  // Stagger reveals — fade list rows in once their section scrolls into view.
  const staggerTargets = document.querySelectorAll<HTMLElement>(
    ".dates-list, .notable-list",
  );
  if (staggerTargets.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.15 },
    );
    staggerTargets.forEach((el) => io.observe(el));
  }
</script>
