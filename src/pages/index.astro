---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Dates from "../components/Dates.astro";
import Notable from "../components/Notable.astro";
import Videos from "../components/Videos.astro";
import Pics from "../components/Pics.astro";
import Shop from "../components/Shop.astro";
import Contact from "../components/Contact.astro";
---

<Base>
  <main class="layout">
    <aside class="hero-rail">
      <Hero />
    </aside>

    <div class="content-rail">
      <section id="shows" class="rail-section">
        <Dates />
        <Notable />
      </section>

      <section id="media" class="rail-section">
        <Videos />
        <Pics />
      </section>

      <section id="shop" class="rail-section">
        <Shop />
      </section>

      <section id="contact" class="rail-section">
        <Contact />
      </section>
    </div>
  </main>
</Base>

<style is:global>
  /* Two-column desktop: sticky hero on the left, scrolling content on the
     right. Mobile collapses to a single column with the hero in normal flow. */
  .layout {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-bg);
  }
  .hero-rail {
    display: block;
  }
  .content-rail {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (min-width: 768px) {
    .content-rail {
      transform: translateX(-50px);
    }
  }
  .rail-section {
    padding: 4rem 1.25rem;
    scroll-margin-top: 1rem;
  }
  .rail-section + .rail-section {
    padding-top: 2rem;
  }

  @media (min-width: 768px) {
    .layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
    .hero-rail {
      position: sticky;
      top: 0;
      height: 100dvh;
      overflow: hidden;
    }
    .content-rail {
      min-width: 0;
    }
    /* Even vertical spread: every section gets the same top + bottom
       padding and the same min-height. */
    .rail-section {
      padding: 5rem 2.5rem;
      min-height: 100dvh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rail {
      position: relative;
      height: auto;
    }
  }
</style>

<script>
  // Stagger reveals — fade list rows in once their section scrolls into view.
  const staggerTargets = document.querySelectorAll<HTMLElement>(
    ".dates-list, .notable-list",
  );
  if (staggerTargets.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.15 },
    );
    staggerTargets.forEach((el) => io.observe(el));
  }
</script>
