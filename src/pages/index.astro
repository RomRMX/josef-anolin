---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Socials from "../components/Socials.astro";
import Dates from "../components/Dates.astro";
import Videos from "../components/Videos.astro";
import Pics from "../components/Pics.astro";
import Notable from "../components/Notable.astro";
import Shop from "../components/Shop.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <main class="stack">
    <article class="card card-hero" data-card="hero">
      <Hero />
    </article>

    <article id="shows" class="card card-grouped card-shows" data-card="shows">
      <div class="card-inner">
        <Socials />
        <Dates />
        <Notable />
      </div>
    </article>

    <article id="media" class="card card-grouped card-media" data-card="media">
      <div class="card-inner">
        <Videos />
        <Pics />
      </div>
    </article>

    {/* Shop article is taller than 100dvh so it stays sticky long enough
        for the tees to scroll fully off-screen before Contact takes over. */}
    <article id="shop" class="card card-shop" data-card="shop">
      <Shop />
    </article>

    <article id="contact" class="card card-grouped card-contact" data-card="contact">
      <div class="card-inner">
        <Contact />
      </div>
    </article>

    <article class="card card-hero card-clone" data-card="hero-clone" aria-hidden="true">
      <Hero />
    </article>

    {/* Tail spacer extends .stack so the shop card stays pinned at top:0 all
        the way until the contact card starts stacking on top. Without it,
        sticky math unsticks shop ~half a viewport early and the title slides
        up before the next card covers it. */}
    <div class="stack-tail" aria-hidden="true"></div>
  </main>
  <Footer />
</Base>

<style is:global>
  /* Stacking-cards layout. Each card is sticky to the top of the viewport.
     As the user scrolls, the next card slides up from below and stacks over
     the previous one. The final card is a Hero clone — when reached, the
     loop script snaps scrollY back to 0 for a seamless infinite scroll. */
  /* Plain block layout so every card shares .stack as its containing block.
     This is what gives sticky cards a range to stick over — display:grid
     would put each card in its own row and break the stacking effect. */
  .stack {
    display: block;
  }
  .card {
    position: sticky;
    top: 0;
    height: 100dvh;
    background: var(--color-bg);
    overflow: hidden;
    /* Each card paints on its own layer so the one below is hidden cleanly. */
    isolation: isolate;
  }
  /* Per-card brand backgrounds. */
  .card-shows { background: #f9feab; }
  .card-media { background: #f7f6f0; }
  .card-shop { background: var(--color-accent-2); }
  .card-contact { background: #c1fc50; }
  .card-grouped .card-inner {
    height: 100%;
    /* No scrollbar inside cards — content is sized to fit 100dvh. */
    overflow: hidden;
    /* 156 + the inner section's 24px py-6 top = 180px from card top to first element. */
    padding-top: 156px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  /* The hero card lets its component lay out full-bleed. */
  .card-hero > section {
    height: 100%;
    padding-top: 250px;
  }
  /* Shop is 250dvh tall so it stays sticky long enough for the tee column
     to scroll off-screen before Contact stacks up. The visible content
     inside is sized to 100dvh and pinned to the top of the article. */
  .card-shop { height: 250dvh; }
  .card-shop > section { height: 100dvh; }
  /* See <div class="stack-tail"> above. 150dvh = the extra height shop has
     beyond a normal card; that's exactly the slack needed to keep shop
     pinned through the contact handoff. */
  .stack-tail { height: 150dvh; }

  /* Mobile keeps the desktop deck stacking — each card sticks at the top
     of the viewport while the next card slides up over it. No internal
     scroll: card content is sized down to fit 100dvh. */
  @media (max-width: 767px) {
    .card-grouped .card-inner {
      /* Mobile header is now ~60px (smaller logo + single row links). */
      padding-top: 4rem;
      padding-bottom: 1rem;
      display: block;
      overflow: hidden;
    }
    /* SHOWS card — compact Socials + Dates + Notable so all three fit
       inside 100dvh without scrolling. */
    .card-shows section {
      padding: 0.5rem 1rem !important;
    }
    .card-shows h2 {
      font-size: 1.5rem !important;
      line-height: 1 !important;
      margin: 0 0 0.4rem 0 !important;
    }
    /* Socials: tighter buttons in tighter row */
    .card-shows section ul.flex { gap: 0.4rem !important; }
    .card-shows section ul a {
      min-height: 1.75rem !important;
      padding: 0.3rem 0.7rem !important;
      font-size: 0.72rem !important;
    }
    /* Dates: switch to inline horizontal rows. date | city/venue | TICKETS */
    .card-shows #dates ul li {
      flex-direction: row !important;
      align-items: center !important;
      gap: 0.6rem !important;
      padding: 0.4rem 0 !important;
    }
    .card-shows #dates ul li > div:first-child {
      font-size: 0.72rem !important;
      width: auto !important;
    }
    .card-shows #dates ul li > div:nth-child(2) {
      flex: 1 !important;
      min-width: 0 !important;
    }
    .card-shows #dates ul li > div:nth-child(2) > div:first-child { font-size: 0.85rem !important; }
    .card-shows #dates ul li > div:nth-child(2) > div:nth-child(2) { font-size: 0.7rem !important; }
    .card-shows #dates ul li > div:nth-child(2) > div:nth-child(3) { display: none !important; }
    .card-shows #dates ul li a {
      align-self: center !important;
      min-height: 1.75rem !important;
      padding: 0.3rem 0.7rem !important;
      font-size: 0.65rem !important;
    }
    /* Notable: tight typography, no extra spacing */
    .card-shows #notable .space-y-6 > * + * { margin-top: 0.4rem !important; }
    .card-shows #notable h3 { font-size: 0.6rem !important; margin-bottom: 0.1rem !important; }
    .card-shows #notable ul { font-size: 0.7rem !important; line-height: 1.2 !important; }
    .card-shows #notable ul li { padding: 0 !important; }
    .card-shows #notable .space-y-1 > * + * { margin-top: 0 !important; }
    .card-shows #notable .grid { gap: 0.5rem !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .card { position: relative; height: auto; }
    .card-grouped .card-inner { height: auto; overflow: visible; justify-content: flex-start; }
    .card-clone { display: none; }
    /* Kill every micro-interaction transition/animation, not just the deck. */
    *, *::before, *::after {
      transition-duration: 0ms !important;
      animation-duration: 0ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<script>
  // Always land on the Hero card after a refresh — the deck loops, so a
  // restored mid-deck scroll position is disorienting.
  if ("scrollRestoration" in history) history.scrollRestoration = "manual";
  window.scrollTo(0, 0);

  // Seamless loop: when the clone hero is fully revealed, snap back to top.
  // Both the original and the clone are visually identical, so the snap is
  // imperceptible. Loop only fires while scrolling down.
  const clone = document.querySelector<HTMLElement>(".card-clone");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (clone && !reduceMotion) {
    let snapping = false;
    let lastY = window.scrollY;

    const onScroll = () => {
      if (snapping) return;
      const y = window.scrollY;
      const goingDown = y > lastY;
      lastY = y;
      // clone.offsetTop is the scroll position at which the clone fully covers
      // the previous card (i.e. it just stuck to the top of the viewport).
      if (goingDown && y >= clone.offsetTop) {
        snapping = true;
        window.scrollTo({ top: 0, behavior: "instant" as ScrollBehavior });
        // Two RAFs to make sure the scroll position has settled before we
        // re-enable, otherwise the next scroll event sees stale state.
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            lastY = 0;
            snapping = false;
          }),
        );
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
