---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Dates from "../components/Dates.astro";
import Notable from "../components/Notable.astro";
import Videos from "../components/Videos.astro";
import Pics from "../components/Pics.astro";
import Shop from "../components/Shop.astro";
import Contact from "../components/Contact.astro";
---

<Base>
  <main class="layout">
    <aside class="hero-rail">
      <Hero />
      <p class="rail-copyright">
        ©2026 <a href="https://www.JosefAnolin.com">www.JosefAnolin.com</a> All Rights Reserved.
      </p>
    </aside>

    <div class="content-rail">
      <section id="shows" class="rail-section">
        <Dates />
        <Notable />
      </section>

      <section id="media" class="rail-section">
        <Videos />
        <Pics />
      </section>

      <section id="shop" class="rail-section">
        <Shop />
      </section>

      <section id="contact" class="rail-section rail-section--contact">
        <Contact />
        <p class="contact-copyright">
          ©2026 <a href="https://www.JosefAnolin.com">www.JosefAnolin.com</a> All Rights Reserved.
        </p>
      </section>
    </div>
  </main>
</Base>

<style is:global>
  /* Two-column desktop: sticky hero on the left, scrolling content on the
     right. Mobile collapses to a single column with the hero in normal flow. */
  .layout {
    display: grid;
    grid-template-columns: 1fr;
    background: transparent;
  }
  .hero-rail {
    display: block;
  }
  .content-rail {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: rgba(0, 0, 0, var(--content-rail-opacity, 0));
  }
  /* 3.5rem top + 3.5rem bottom = 7rem between every section, matching the
     7rem gap used between sub-sections (SHOWS/APPEARANCES, VIDEOS/PHOTOS) so
     the spacing between all content areas is equal. */
  .rail-section {
    padding: 3.5rem 1.25rem;
    scroll-margin-top: 1rem;
  }
  /* Extra breathing room below HIT ME UP at the bottom of the page. */
  .rail-section--contact {
    padding-bottom: 7rem;
  }

  /* Two-column layout kicks in at >= 900px (was 1024). */
  @media (min-width: 900px) {
    .layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
    .hero-rail {
      position: sticky;
      top: 0;
      height: 100dvh;
      overflow: hidden;
    }
    .content-rail {
      min-width: 0;
    }
    /* Asymmetric padding: 50px breathing room on the left between the
       sticky hero column and content, and 2.5rem on the right edge.
       Even, generous vertical padding spaces the sections consistently
       (no forced 100dvh, which left short sections mostly empty). */
    .rail-section {
      padding: 3.5rem 2.5rem 3.5rem 50px;
    }
    /* Contact section keeps the same top padding as the other sections so
       the gap between sections is equal; extra padding below gives HIT ME UP
       breathing room at the bottom of the page. */
    .rail-section--contact {
      display: flex;
      flex-direction: column;
      padding-bottom: 10rem;
    }
    /* Cap col2 content at 600px wide — the section-h2's stay full-rail
       width so their hairlines can still bleed to the viewport edge. */
    .dates-list,
    #notable .notable-list,
    .videos-grid,
    .pics-grid,
    .tee-list,
    .contact-lede,
    .contact-form {
      max-width: 600px;
    }
  }

  /* Page copyright lives in the contact section so it sits at the bottom
     of the screen when HIT ME UP is in view. Reuses the --hero-copyright-*
     vars so the playground's Copyright sliders still apply. */
  .contact-copyright {
    margin: var(--hero-copyright-margin-top, 1.5rem) 0 0;
    font-size: var(--hero-copyright-fs, 0.7rem);
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.45);
    text-align: center;
  }
  .contact-copyright a {
    color: inherit;
    text-decoration: none;
  }
  .contact-copyright a:hover {
    color: var(--color-accent);
  }
  @media (min-width: 900px) {
    .rail-section--contact .contact-copyright {
      margin-top: auto;
      padding-top: 2rem;
    }
  }

  /* Left-column footer. On desktop the copyright lives at the bottom of the
     sticky hero rail; on mobile it falls back to the contact-section copy
     (the rail one is hidden, the contact one shows at the page bottom). */
  .rail-copyright {
    display: none;
  }
  .rail-copyright a {
    color: inherit;
    text-decoration: none;
  }
  .rail-copyright a:hover {
    color: var(--color-accent);
  }
  @media (min-width: 900px) {
    .rail-copyright {
      display: block;
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0.5rem;
      padding: 0 2rem;
      font-size: var(--hero-copyright-fs, 0.7rem);
      letter-spacing: 0.04em;
      color: rgba(255, 255, 255, 0.45);
      text-align: center;
    }
    /* Desktop shows the rail copyright instead of the contact one. */
    .rail-section--contact .contact-copyright {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rail {
      position: relative;
      height: auto;
    }
  }
</style>

<script>
  // Stagger reveals — fade list rows in once their section scrolls into view.
  const staggerTargets = document.querySelectorAll<HTMLElement>(
    ".dates-list, .notable-list",
  );
  if (staggerTargets.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.15 },
    );
    staggerTargets.forEach((el) => io.observe(el));
  }
</script>
