---
import "../../styles/global.css";
import { isAuthed, passwordLoginEnabled } from "../../lib/auth";
import { storeBackend } from "../../lib/content";
import { googleLoginEnabled } from "../../lib/google";

// On-demand: this page reads the session cookie at request time.
export const prerender = false;

const authed = await isAuthed(Astro.cookies);
const passwordEnabled = passwordLoginEnabled();
const googleEnabled = googleLoginEnabled();
const anyLogin = passwordEnabled || googleEnabled;
const backend = storeBackend();

// Errors bounced back from the Google OAuth callback (?error=…).
const LOGIN_ERRORS: Record<string, string> = {
  "not-allowed": "That Google account isn’t authorized for this site.",
  "google-denied": "Google sign-in was cancelled.",
  "google-failed": "Couldn’t verify your Google account. Please try again.",
  "google-not-configured": "Google sign-in isn’t set up yet.",
  "bad-state": "Your sign-in link expired. Please try again.",
};
const errorKey = Astro.url.searchParams.get("error");
const loginError = errorKey ? (LOGIN_ERRORS[errorKey] ?? "Couldn’t sign in. Please try again.") : null;

const navItems = [
  { id: "card-hero", label: "Hero" },
  { id: "card-shows", label: "Shows" },
  { id: "card-appearances", label: "Appearances" },
  { id: "card-videos", label: "Videos" },
  { id: "card-photos", label: "Photos" },
  { id: "card-social-links", label: "Socials" },
  { id: "card-contact", label: "Contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/png" href="/joe-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Site Editor — Josef Anolin</title>
  </head>

  <body class="admin-body">
    {!authed && (
      <main class="login-wrap">
        <div class="login-card">
          <img src="/joedobo_straightlogo.png" alt="Josef Anolin" class="login-logo" />
          <h1 class="login-title">SITE EDITOR</h1>

          {loginError && <p class="login-error">{loginError}</p>}

          {anyLogin ? (
            <>
              <p class="login-sub">Sign in to make updates.</p>

              {googleEnabled && (
                <a class="google-btn" href="/api/admin/auth/google">
                  <svg class="google-g" viewBox="0 0 48 48" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                  </svg>
                  Sign in with Google
                </a>
              )}

              {googleEnabled && passwordEnabled && <div class="login-or"><span>or</span></div>}

              {passwordEnabled && (
                <form class="login-pw" id="login-form" autocomplete="off">
                  <label class="fld">
                    <span class="fld-label">Password</span>
                    <input type="password" name="password" id="login-password" class="fld-input" required />
                  </label>
                  <p class="login-error" id="login-error" hidden></p>
                  <button type="submit" class="primary-btn" id="login-btn">Log in</button>
                </form>
              )}
            </>
          ) : (
            <p class="login-sub login-sub--warn">
              Login isn’t set up yet. Configure Google sign-in
              (<code>GOOGLE_CLIENT_ID</code>, <code>GOOGLE_CLIENT_SECRET</code>,
              <code>ADMIN_ALLOWED_EMAILS</code>) or an <code>ADMIN_PASSWORD</code> in
              Vercel, then redeploy.
            </p>
          )}
        </div>
      </main>
    )}

    {authed && (
      <div class="admin-shell" data-editor>
        <header class="topbar">
          <div class="topbar-left">
            <span class="topbar-title">SITE EDITOR</span>
            <span class="store-pill" data-backend={backend}>
              {backend === "kv" ? "Saving to cloud store" : backend === "local-file" ? "Local dev store" : "No store"}
            </span>
          </div>
          <div class="topbar-right">
            <span class="save-status" id="save-status" data-dirty="false">All changes saved</span>
            <a class="ghost-btn" href="/" target="_blank" rel="noopener">View site ↗</a>
            <button type="button" class="ghost-btn" id="logout-btn">Log out</button>
            <button type="button" class="primary-btn" id="save-btn" disabled>Save changes</button>
          </div>
        </header>

        <nav class="section-nav" aria-label="Sections">
          {navItems.map((n) => (
            <a href={`#${n.id}`} data-jump={n.id} class="section-nav-link">{n.label}</a>
          ))}
        </nav>

        <p class="readonly-banner" id="readonly-banner" hidden>
          ⚠ No writable content store is configured, so changes can’t be saved.
          Add a KV store and set <code>KV_REST_API_URL</code> + <code>KV_REST_API_TOKEN</code> in Vercel.
        </p>

        <main class="editor-sections" id="editor-sections">
          <p class="loading-note">Loading…</p>
        </main>

        <div class="toast" id="toast" data-show="false"></div>
      </div>
    )}

    {/* One script handles both states — it self-detects whether the editor
        shell or the login form is on the page. (Astro hoists <script> tags
        page-globally, so a single unconditional one is the reliable pattern.) */}
    <script>
      import "../../scripts/admin-editor.ts";
    </script>

    <style is:global>
      .admin-body {
        background: #0c0c0d;
        color: var(--color-ink);
        font-family: var(--font-sans);
        min-height: 100dvh;
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }

      /* ---------- shared form fields ---------- */
      .fld { display: flex; flex-direction: column; gap: 0.35rem; }
      .fld-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 600;
      }
      .fld-input {
        background: #18181b;
        color: #f5f5f5;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 7px;
        padding: 0.6rem 0.75rem;
        font-size: 0.95rem;
        font-family: var(--font-sans);
        width: 100%;
        box-sizing: border-box;
      }
      textarea.fld-input { resize: vertical; line-height: 1.5; }
      .fld-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 35%, transparent);
      }
      .fld-hint { font-size: 0.74rem; color: rgba(255, 255, 255, 0.4); }

      .primary-btn {
        background: var(--color-accent);
        color: #fff;
        border: 0;
        border-radius: 7px;
        padding: 0.6rem 1.15rem;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: filter 140ms ease, transform 120ms ease;
      }
      .primary-btn:hover:not(:disabled) { filter: brightness(1.1); }
      .primary-btn:active:not(:disabled) { transform: scale(0.98); }
      .primary-btn:disabled { opacity: 0.4; cursor: not-allowed; }

      .ghost-btn {
        background: transparent;
        color: rgba(255, 255, 255, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 7px;
        padding: 0.5rem 0.85rem;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: border-color 140ms ease, color 140ms ease;
      }
      .ghost-btn:hover { color: #fff; border-color: rgba(255, 255, 255, 0.4); }

      /* ---------- login ---------- */
      .login-wrap { min-height: 100dvh; display: grid; place-items: center; padding: 1.5rem; }
      .login-card {
        width: min(380px, 100%);
        background: #141416;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 2rem 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
      }
      .login-logo { height: 54px; width: auto; align-self: center; }
      .login-title {
        font-family: var(--font-display);
        letter-spacing: 0.05em;
        text-align: center;
        margin: 0;
        font-size: 1.6rem;
        color: #fff;
      }
      .login-sub { text-align: center; color: rgba(255, 255, 255, 0.6); margin: 0; font-size: 0.9rem; }
      .login-sub--warn { color: var(--color-highlight); line-height: 1.5; }
      .login-sub code, .readonly-banner code {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.1em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
      }
      .login-error { color: #ff6b6b; font-size: 0.85rem; margin: 0; text-align: center; }
      .login-pw { display: flex; flex-direction: column; gap: 1rem; margin: 0; }

      .google-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        background: #fff;
        color: #1f1f1f;
        border: 0;
        border-radius: 8px;
        padding: 0.7rem 1rem;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: var(--font-sans);
        text-decoration: none;
        cursor: pointer;
        transition: filter 140ms ease, transform 120ms ease;
      }
      .google-btn:hover { filter: brightness(0.96); }
      .google-btn:active { transform: scale(0.98); }
      .google-g { width: 18px; height: 18px; flex: 0 0 auto; }

      .login-or {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.35);
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .login-or::before,
      .login-or::after {
        content: "";
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.12);
      }

      /* ---------- editor shell ---------- */
      .admin-shell { max-width: 880px; margin: 0 auto; padding-bottom: 5rem; }
      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 0.85rem 1.1rem;
        background: rgba(12, 12, 13, 0.92);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
      .topbar-title { font-family: var(--font-display); font-size: 1.15rem; letter-spacing: 0.06em; }
      .store-pill {
        font-size: 0.68rem;
        letter-spacing: 0.04em;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.6);
        white-space: nowrap;
      }
      .store-pill[data-backend="kv"] { color: #7ee787; border-color: rgba(126, 231, 135, 0.4); }
      .store-pill[data-backend="none"] { color: #ff8a8a; border-color: rgba(255, 138, 138, 0.4); }
      .topbar-right { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
      .save-status { font-size: 0.78rem; color: rgba(255, 255, 255, 0.45); }
      .save-status[data-dirty="true"] { color: var(--color-highlight); }

      .section-nav {
        display: flex;
        gap: 0.4rem;
        overflow-x: auto;
        padding: 0.65rem 1.1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        position: sticky;
        top: 56px;
        z-index: 15;
        background: rgba(12, 12, 13, 0.9);
        backdrop-filter: blur(10px);
        scrollbar-width: none;
      }
      .section-nav::-webkit-scrollbar { display: none; }
      .section-nav-link {
        flex: 0 0 auto;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
      }
      .section-nav-link:hover { color: #fff; border-color: var(--color-accent); }

      .readonly-banner {
        margin: 1rem 1.1rem 0;
        padding: 0.75rem 1rem;
        background: rgba(255, 138, 138, 0.12);
        border: 1px solid rgba(255, 138, 138, 0.35);
        border-radius: 8px;
        font-size: 0.85rem;
        line-height: 1.5;
      }

      .editor-sections { padding: 1.1rem; display: flex; flex-direction: column; gap: 1.1rem; }
      .loading-note { color: rgba(255, 255, 255, 0.4); }

      .ed-card {
        background: #141416;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        overflow: hidden;
        scroll-margin-top: 110px;
      }
      .ed-card-head {
        padding: 1rem 1.15rem 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }
      .ed-card-head h2 {
        margin: 0;
        font-family: var(--font-display);
        font-size: 1.3rem;
        letter-spacing: 0.04em;
        color: #fff;
      }
      .ed-card-hint { margin: 0.3rem 0 0; font-size: 0.82rem; color: rgba(255, 255, 255, 0.5); line-height: 1.45; }
      .ed-card-body { padding: 1.15rem; display: flex; flex-direction: column; gap: 1rem; }

      /* ---------- lists ---------- */
      .list { display: flex; flex-direction: column; gap: 0.85rem; }
      .list-row {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        padding: 0.85rem;
        background: #1b1b1f;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 9px;
      }
      .row-fields { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.7rem; }
      .row-fields--grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
      .row-ctls { display: flex; flex-direction: column; gap: 0.3rem; flex: 0 0 auto; }
      .row-ctl {
        width: 30px;
        height: 30px;
        display: grid;
        place-items: center;
        background: #232328;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.75);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        line-height: 1;
        transition: background 120ms ease, color 120ms ease;
      }
      .row-ctl:hover { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }

      .subitems { display: flex; flex-direction: column; gap: 0.45rem; }
      .subitem { display: flex; gap: 0.35rem; align-items: center; }
      .subitem .fld-input { flex: 1; }

      .empty-note { color: rgba(255, 255, 255, 0.45); font-size: 0.88rem; font-style: italic; margin: 0; }

      .add-btn {
        align-self: flex-start;
        background: transparent;
        border: 1px dashed rgba(255, 255, 255, 0.25);
        color: rgba(255, 255, 255, 0.75);
        border-radius: 7px;
        padding: 0.5rem 0.9rem;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: color 120ms ease, border-color 120ms ease;
      }
      .add-btn:hover { color: var(--color-accent); border-color: var(--color-accent); }
      .add-btn--ghost { border-style: solid; }
      .btn-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }

      .vid-thumb { width: 80px; height: 60px; object-fit: cover; border-radius: 6px; flex: 0 0 auto; background: #000; }

      /* ---------- photos ---------- */
      .pic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.7rem; }
      .pic-cell {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        background: #000;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .pic-preview { width: 100%; height: 100%; object-fit: cover; }
      .pic-ctls {
        position: absolute;
        inset: auto 0 0 0;
        display: flex;
        justify-content: center;
        gap: 0.3rem;
        padding: 0.35rem;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.85), transparent);
      }

      /* ---------- toast ---------- */
      .toast {
        position: fixed;
        bottom: 1.25rem;
        left: 50%;
        transform: translate(-50%, 1rem);
        background: #1f1f23;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        padding: 0.7rem 1.1rem;
        font-size: 0.88rem;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
        opacity: 0;
        pointer-events: none;
        transition: opacity 200ms ease, transform 200ms ease;
        z-index: 50;
        max-width: 90vw;
        text-align: center;
      }
      .toast[data-show="true"] { opacity: 1; transform: translate(-50%, 0); }
      .toast[data-error="true"] { border-color: rgba(255, 107, 107, 0.6); color: #ffb4b4; }

      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
      }

      @media (max-width: 620px) {
        .row-fields--grid2 { grid-template-columns: 1fr; }
        .topbar-right { width: 100%; justify-content: space-between; }
        .topbar-right .save-status { order: -1; width: 100%; }
        .section-nav { top: 96px; }
      }
    </style>
  </body>
</html>
