---
import "../styles/global.css";
import Header from "../components/Header.astro";
import MobileSocialBar from "../components/MobileSocialBar.astro";
import CartDrawer from "../components/CartDrawer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Josef Anolin — Stand-Up Comedian",
  description = "Stand-up comedian from Oakland, California. Currently based in Los Angeles.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/joe-hero.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Covered+By+Your+Grace&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#contact"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:px-4 focus:py-2 focus:bg-black focus:text-[color:var(--color-accent)] focus:rounded focus:font-bold focus:tracking-widest focus:text-sm"
    >
      Skip to contact
    </a>
    <Header />
    <slot />
    <MobileSocialBar />
    <CartDrawer />

    {/* Floating back-to-top. Hidden until the user has scrolled past the
        first viewport; clicking returns to the hero card. Smaller on mobile
        so it doesn't crowd the bottom social bar. */}
    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="back-to-top fixed bottom-[75px] right-3 min-[900px]:bottom-5 min-[900px]:right-5 z-40 w-[36px] h-[36px] min-[900px]:w-12 min-[900px]:h-12 grid place-items-center rounded-full bg-black text-[color:var(--color-accent)] border-2 border-[color:var(--color-accent)] min-[900px]:border-0 opacity-0 pointer-events-none translate-y-2 hover:bg-neutral-800"
    >
      <svg class="w-3.5 h-3.5 min-[900px]:w-5 min-[900px]:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5" />
        <path d="m5 12 7-7 7 7" />
      </svg>
    </button>

    <style>
      .back-to-top {
        transition: opacity 220ms var(--ease-out-strong),
                    transform 220ms var(--ease-out-strong),
                    background-color 160ms var(--ease-out-strong);
      }
      .back-to-top:active { transform: scale(0.93) !important; }
      @media (prefers-reduced-motion: reduce) {
        .back-to-top { transition: opacity 200ms ease; }
        .back-to-top:active { transform: none !important; }
      }
    </style>

    <script>
      const btn = document.getElementById("back-to-top");
      if (btn) {
        const update = () => {
          const visible = window.scrollY > window.innerHeight * 0.6;
          btn.classList.toggle("opacity-100", visible);
          btn.classList.toggle("opacity-0", !visible);
          btn.classList.toggle("pointer-events-auto", visible);
          btn.classList.toggle("pointer-events-none", !visible);
          btn.classList.toggle("translate-y-0", visible);
          btn.classList.toggle("translate-y-2", !visible);
        };
        btn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
        window.addEventListener("scroll", update, { passive: true });
        update();
      }
    </script>
  </body>
</html>
